#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"

module ValidateReviewFindings
  SCHEMA = "review-finding-v0"
  REQUIRED_FINDING_FIELDS = %w[
    id
    source
    target
    severity
    disposition
    title
    body
    verification
  ].freeze
  REQUIRED_VERIFICATION_FIELDS = %w[status current_head_state].freeze
  SEVERITIES = %w[P0 P1 P2 P3 INFO].freeze
  DISPOSITIONS = %w[
    must_fix
    needs_decision
    should_fix
    accepted_fixed
    deferred
    waived_by_maintainer
    rejected_false_positive
    rejected_not_actionable
    unknown
  ].freeze
  VERIFICATION_STATUSES = %w[unverified verified contradicted unknown].freeze
  CURRENT_HEAD_STATES = %w[current stale not_applicable unknown].freeze
  RISK_LENS_STATUSES = %w[applied not_applicable degraded unknown].freeze
  COVERAGE_STATUSES = %w[complete partial unknown].freeze
  INDEPENDENT_VALIDATION_STATUSES = %w[confirmed rejected degraded].freeze
  RECEIPT_TARGET_KINDS = %w[committed uncommitted].freeze
  RECEIPT_SOURCES = %w[
    autoreview
    adversarial-pr-review
    continuous-evaluation-loop
    post-merge-audit
    address-review
  ].freeze
  PROVENANCE_USAGE_FIELDS = %w[input_tokens output_tokens cache_read_tokens total_tokens].freeze
  STRING_ARRAY_FIELDS = %w[evidence links related_ids].freeze

  module_function

  def run(path)
    failures = validate_path(path)

    if failures.empty?
      puts "PASS review finding schema"
      0
    else
      warn failures.join("\n")
      1
    end
  end

  def validate_path(path)
    text = File.read(path, encoding: "UTF-8")
    if File.extname(path).casecmp(".md").zero?
      validate_markdown(text, path)
    else
      validate_json_block(text, path)
    end
  rescue SystemCallError => e
    ["#{path}: #{e.message}"]
  end

  def validate_markdown(text, path)
    blocks = extract_blocks(text)
    return ["#{path}: missing ```json review-findings fenced block"] if blocks.empty?

    blocks.each_with_index.flat_map do |block, index|
      validate_json_block(block, "#{path}: review-findings block #{index + 1}")
    end
  end

  def extract_blocks(text)
    text.scan(/^```json[ \t]+review-findings\n(.*?)^```\s*$/m).flatten
  end

  def validate_json_block(text, label)
    document = JSON.parse(text)
    validate_document(document, label)
  rescue JSON::ParserError => e
    ["#{label}: invalid JSON: #{e.message}"]
  end

  def validate_document(document, label)
    failures = []
    unless document.is_a?(Hash)
      return ["#{label}: top-level value must be a JSON object"]
    end

    failures << "#{label}: schema must be #{SCHEMA.inspect}" unless document["schema"] == SCHEMA
    findings = document["review_findings"]
    if document.key?("review_receipt")
      failures.concat(validate_review_receipt(document["review_receipt"], "#{label}: review_receipt"))
    end
    unless findings.is_a?(Array)
      failures << "#{label}: review_findings must be an array"
      return failures
    end

    receipt = document["review_receipt"]
    receipt_target = receipt["target"] if receipt.is_a?(Hash)
    receipt_head = receipt_target["head_sha"] if receipt_target.is_a?(Hash)
    failures.concat(validate_findings(findings, label, receipt_present: document.key?("review_receipt"), receipt_head:))
    failures
  end

  def validate_review_receipt(receipt, label)
    return ["#{label} must be an object"] unless receipt.is_a?(Hash)

    failures = []
    if non_empty_string?(receipt["source"])
      unless RECEIPT_SOURCES.include?(receipt["source"])
        failures << "#{label}.source must be one of: #{RECEIPT_SOURCES.join(', ')}"
      end
    else
      failures << "#{label}.source must be a non-empty string"
    end
    failures.concat(validate_receipt_target(receipt["target"], label))
    failures.concat(validate_provenance(receipt["provenance"], label))
    failures.concat(validate_risk_lenses(receipt["risk_lenses"], label))
    failures.concat(validate_autoreview_lenses(receipt, label))
    failures.concat(validate_coverage(receipt["coverage"], label))
    failures.concat(validate_complete_coverage(receipt, label))
    failures.concat(validate_uncommitted_coverage(receipt, label))
    failures
  end

  def validate_provenance(provenance, label)
    provenance_label = "#{label}: provenance"
    failures = validate_required_string_fields(provenance, %w[engine invocation], provenance_label)
    return failures unless provenance.is_a?(Hash)

    %w[model effort].each do |field|
      next unless provenance.key?(field)

      unless non_empty_string?(provenance[field])
        failures << "#{provenance_label}.#{field} must be a non-empty string"
      end
      if unknown_sentinel_variant?(provenance[field])
        failures << "#{provenance_label}.#{field} must use literal UNKNOWN when unknown"
      end
    end

    return failures unless provenance.key?("usage")
    return failures if provenance["usage"] == "UNKNOWN"

    unless provenance["usage"].is_a?(Hash)
      failures << "#{provenance_label}.usage must be an object or literal UNKNOWN"
      return failures
    end

    PROVENANCE_USAGE_FIELDS.each do |field|
      unless provenance.fetch("usage").key?(field)
        failures << "#{provenance_label}.usage.#{field} must be present"
        next
      end
      next if nonnegative_integer_or_unknown?(provenance.dig("usage", field))

      failures << "#{provenance_label}.usage.#{field} must be a nonnegative integer or UNKNOWN"
    end
    input_tokens = provenance.dig("usage", "input_tokens")
    output_tokens = provenance.dig("usage", "output_tokens")
    total_tokens = provenance.dig("usage", "total_tokens")
    known_primary_tokens = [input_tokens, output_tokens].select { |value| value.is_a?(Integer) }.sum
    if total_tokens.is_a?(Integer) && total_tokens < known_primary_tokens
      failures << "#{provenance_label}.usage.total_tokens cannot be less than " \
                  "known input_tokens + output_tokens"
    end
    failures
  end

  def validate_receipt_target(target, label)
    failures = validate_required_string_fields(target, %w[base_ref base_sha head_sha], "#{label}: target")
    if target.is_a?(Hash) && !RECEIPT_TARGET_KINDS.include?(target["kind"])
      failures << "#{label}: target.kind must be one of: #{RECEIPT_TARGET_KINDS.join(', ')}"
    end
    if target.is_a?(Hash) && target["kind"] == "committed"
      %w[base_sha head_sha].each do |field|
        next unless non_empty_string?(target[field])
        next if full_git_object_id?(target[field])

        failures << "#{label}: committed target.#{field} must be a full hexadecimal Git object ID"
      end
      base_sha = target["base_sha"]
      head_sha = target["head_sha"]
      if full_git_object_id?(base_sha) && full_git_object_id?(head_sha) && base_sha.length != head_sha.length
        failures << "#{label}: committed target base_sha and head_sha must use the same Git object format"
      end
    end
    failures
  end

  def validate_uncommitted_coverage(receipt, label)
    target = receipt["target"]
    coverage = receipt["coverage"]
    return [] unless target.is_a?(Hash) && target["kind"] == "uncommitted" && coverage.is_a?(Hash)

    limitations = coverage["limitations"]
    return [] if %w[partial unknown].include?(coverage["status"]) && limitations.is_a?(Array) && !limitations.empty?

    ["#{label}: uncommitted target requires partial or unknown coverage with limitations"]
  end

  def validate_complete_coverage(receipt, label)
    coverage = receipt["coverage"]
    return [] unless coverage.is_a?(Hash) && coverage["status"] == "complete"

    lenses = receipt["risk_lenses"]
    degraded_lens = lenses.is_a?(Array) && lenses.any? do |lens|
      lens.is_a?(Hash) && %w[degraded unknown].include?(lens["status"])
    end
    excluded = coverage["excluded_paths"]
    limitations = coverage["limitations"]
    incomplete = degraded_lens || excluded.is_a?(Array) && !excluded.empty? ||
                 limitations.is_a?(Array) && !limitations.empty?
    return [] unless incomplete

    ["#{label}: complete coverage cannot include degraded or unknown lenses, excluded paths, or limitations"]
  end

  def validate_required_string_fields(object, fields, label)
    return ["#{label} must be an object"] unless object.is_a?(Hash)

    fields.filter_map do |field|
      "#{label}.#{field} must be a non-empty string" unless non_empty_string?(object[field])
    end
  end

  def validate_risk_lenses(lenses, label)
    return ["#{label}: risk_lenses must be a non-empty array"] unless lenses.is_a?(Array) && !lenses.empty?

    failures = lenses.each_with_index.flat_map do |lens, index|
      lens_label = "#{label}: risk_lenses[#{index}]"
      if lens.is_a?(Hash)
        lens_failures = validate_required_string_fields(lens, %w[name reason], lens_label) +
                        validate_enum(lens, "status", RISK_LENS_STATUSES, lens_label)
        lens_failures << "#{lens_label}.status must be present" unless lens.key?("status")
        lens_failures
      else
        ["#{lens_label} must be an object"]
      end
    end
    names = lenses.filter_map { |lens| lens["name"] if lens.is_a?(Hash) && non_empty_string?(lens["name"]) }
    failures << "#{label}: risk_lenses names must be unique" unless names.uniq.length == names.length
    failures
  end

  def validate_autoreview_lenses(receipt, label)
    return [] unless receipt["source"] == "autoreview" && receipt["risk_lenses"].is_a?(Array)

    names = receipt["risk_lenses"].filter_map { |lens| lens["name"] if lens.is_a?(Hash) }
    missing = %w[correctness security] - names
    return [] if missing.empty?

    ["#{label}: autoreview risk_lenses must include: #{missing.join(', ')}"]
  end

  def validate_coverage(coverage, label)
    return ["#{label}: coverage must be an object"] unless coverage.is_a?(Hash)

    failures = validate_enum(coverage, "status", COVERAGE_STATUSES, "#{label}: coverage")
    failures << "#{label}: coverage.status must be present" unless coverage.key?("status")
    %w[included_paths excluded_paths limitations].each do |field|
      failures.concat(validate_string_array(coverage, field, "#{label}: coverage"))
      failures << "#{label}: coverage.#{field} must be present" unless coverage.key?(field)
    end
    failures
  end

  def validate_findings(findings, label, receipt_present: false, receipt_head: nil)
    seen_ids = {}
    findings.each_with_index.flat_map do |finding, index|
      finding_label = "#{label}: review_findings[#{index}]"
      failures = validate_finding(finding, finding_label, receipt_present:, receipt_head:)
      id = finding["id"] if finding.is_a?(Hash)
      failures << "#{finding_label}: id must be unique within the report" if id && seen_ids[id]
      seen_ids[id] = true if id
      failures
    end
  end

  def validate_finding(finding, label, receipt_present: false, receipt_head: nil)
    return ["#{label}: finding must be an object"] unless finding.is_a?(Hash)

    failures = []
    missing = REQUIRED_FINDING_FIELDS.reject { |field| finding.key?(field) }
    failures << "#{label}: missing required fields: #{missing.join(', ')}" unless missing.empty?

    %w[id source title body].each do |field|
      next unless finding.key?(field)

      failures << "#{label}: #{field} must be a non-empty string" unless non_empty_string?(finding[field])
    end

    failures.concat(validate_target(finding["target"], label)) if finding.key?("target")
    finding_target = finding["target"]
    finding_head = finding_target["head_sha"] if finding_target.is_a?(Hash)
    if non_empty_string?(receipt_head) && finding_target.is_a?(Hash) && finding_target.key?("head_sha")
      if !non_empty_string?(finding_head)
        failures << "#{label}: target.head_sha must be a non-empty string when review_receipt target is present"
      elsif !receipt_head.casecmp?(finding_head)
        failures << "#{label}: target.head_sha must match review_receipt.target.head_sha"
      end
    end
    failures.concat(validate_enum(finding, "severity", SEVERITIES, label))
    failures.concat(validate_enum(finding, "disposition", DISPOSITIONS, label))
    failures.concat(validate_verification(finding["verification"], label)) if finding.key?("verification")
    if finding.key?("consequential") && ![true, false].include?(finding["consequential"])
      failures << "#{label}: consequential must be true or false"
    end
    consequential = (receipt_present && %w[P0 P1].include?(finding["severity"])) || finding["consequential"] == true
    if consequential && !finding.key?("independent_validation")
      failures << "#{label}: consequential finding requires independent_validation"
    end
    if finding.key?("independent_validation")
      failures.concat(validate_independent_validation(finding["independent_validation"], label))
    end
    validation = finding["independent_validation"]
    if validation.is_a?(Hash)
      validation_status = validation["status"]
      disposition = finding["disposition"]
      if validation_status == "confirmed" && disposition.to_s.start_with?("rejected_")
        failures << "#{label}: confirmed independent validation cannot use a rejected disposition"
      elsif validation_status == "rejected" &&
            !%w[rejected_false_positive rejected_not_actionable unknown].include?(disposition)
        failures << "#{label}: rejected independent validation requires a rejected or unknown disposition"
      elsif consequential && validation_status == "degraded" &&
            !%w[must_fix needs_decision unknown].include?(disposition)
        failures << "#{label}: degraded independent validation requires must_fix, needs_decision, or unknown disposition"
      end
    end
    failures.concat(validate_location(finding["location"], label)) if finding.key?("location")
    STRING_ARRAY_FIELDS.each { |field| failures.concat(validate_string_array(finding, field, label)) }
    failures
  end

  def validate_target(target, label)
    unless target.is_a?(Hash) && !target.empty?
      return ["#{label}: target must be a non-empty object"]
    end

    []
  end

  def validate_verification(verification, label)
    return ["#{label}: verification must be an object"] unless verification.is_a?(Hash)

    failures = []
    missing = REQUIRED_VERIFICATION_FIELDS.reject { |field| verification.key?(field) }
    failures << "#{label}: verification missing required fields: #{missing.join(', ')}" unless missing.empty?
    failures.concat(validate_enum(verification, "status", VERIFICATION_STATUSES, "#{label}: verification"))
    failures.concat(validate_enum(verification, "current_head_state", CURRENT_HEAD_STATES, "#{label}: verification"))
    failures
  end

  def validate_location(location, label)
    return ["#{label}: location must be an object"] unless location.is_a?(Hash)

    failures = []
    %w[file symbol url].each do |field|
      next unless location.key?(field)

      failures << "#{label}: location.#{field} must be a non-empty string" unless non_empty_string?(location[field])
    end
    %w[line end_line].each do |field|
      next unless location.key?(field)

      failures << "#{label}: location.#{field} must be a positive integer" unless positive_integer?(location[field])
    end
    failures
  end

  def validate_independent_validation(validation, label)
    validation_label = "#{label}: independent_validation"
    return ["#{validation_label} must be an object"] unless validation.is_a?(Hash)

    failures = validate_enum(validation, "status", INDEPENDENT_VALIDATION_STATUSES, validation_label)
    failures << "#{label}: independent_validation.status must be present" unless validation.key?("status")
    unless non_empty_string?(validation["validator"])
      failures << "#{label}: independent_validation.validator must be a non-empty string"
    end
    evidence = validation["evidence"]
    unless evidence.is_a?(Array) && !evidence.empty? && evidence.all? { |entry| non_empty_string?(entry) }
      failures << "#{label}: independent_validation.evidence must be a non-empty array of strings"
    end
    failures
  end

  def validate_string_array(finding, field, label)
    return [] unless finding.key?(field)

    value = finding[field]
    if !value.is_a?(Array)
      ["#{label}: #{field} must be an array"]
    elsif value.any? { |entry| !non_empty_string?(entry) }
      ["#{label}: #{field} entries must be non-empty strings"]
    else
      []
    end
  end

  def validate_enum(object, field, allowed, label)
    return [] unless object.key?(field)

    allowed.include?(object[field]) ? [] : ["#{label}: #{field} must be one of: #{allowed.join(', ')}"]
  end

  def non_empty_string?(value)
    value.is_a?(String) && !value.strip.empty?
  end

  def positive_integer?(value)
    value.is_a?(Integer) && value.positive?
  end

  def nonnegative_integer_or_unknown?(value)
    value == "UNKNOWN" || value.is_a?(Integer) && !value.negative?
  end

  def unknown_sentinel_variant?(value)
    value.is_a?(String) && value.strip.casecmp?("UNKNOWN") && value != "UNKNOWN"
  end

  def full_git_object_id?(value)
    value.is_a?(String) && value.match?(/\A(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})\z/)
  end
end

if $PROGRAM_NAME == __FILE__
  path = ARGV.fetch(0, File.expand_path("../docs/review-finding-schema.md", __dir__))
  exit ValidateReviewFindings.run(path)
end
