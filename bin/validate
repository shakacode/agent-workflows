#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")/.."

echo "== skill frontmatter =="
ruby - <<'RUBY'
require "yaml"

failures = []
Dir.glob("skills/*/SKILL.md").sort.each do |path|
  text = File.read(path, encoding: "UTF-8")
  unless text.start_with?("---\n")
    failures << "#{path}: missing YAML frontmatter"
    next
  end

  closing = text.index("\n---\n", 4)
  if closing.nil?
    failures << "#{path}: unterminated YAML frontmatter"
    next
  end

  frontmatter = YAML.safe_load(text[4...closing], aliases: false) || {}
  name = frontmatter["name"]
  description = frontmatter["description"]
  folder = File.basename(File.dirname(path))

  failures << "#{path}: name must match folder #{folder.inspect}" unless name == folder
  failures << "#{path}: description is required" if description.to_s.strip.empty?
end

if failures.empty?
  puts "PASS #{Dir.glob("skills/*/SKILL.md").length} skills"
else
  warn failures.join("\n")
  exit 1
end
RUBY

echo "== seam doctor unit tests =="
ruby bin/agent-workflow-seam-doctor-test.rb

echo "== fixture seam validation =="
bin/agent-workflow-seam-doctor --root test/fixtures/consumer-repo --shared .

echo "== helper tests =="
ruby skills/address-review/bin/fetch-pr-review-data-test.rb
ruby skills/plan-pr-batch/bin/pr-file-touch-map-test.rb
ruby skills/plan-pr-batch/scripts/check_goal_prompt_size.rb
bash skills/post-merge-audit/bin/post-merge-audit-scope-test.bash
ruby skills/pr-batch/bin/pr-ci-readiness-test.rb
ruby skills/pr-batch/bin/pr-security-preflight-test.rb
ruby skills/update-changelog/bin/changelog-merged-prs-test.rb

echo "PASS agent-workflows validation"
