#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "open3"
require "optparse"
# Ruby versions before 3.2 do not load Set by default.
# rubocop:disable Lint/RedundantRequireStatement
require "set"
# rubocop:enable Lint/RedundantRequireStatement
require "time"

module AgentWorkflowsTrustAudit
  DEFAULT_LIMIT = 10
  MAX_CLOSED_PR_PAGES = 20
  TRUSTED_USER_PERMISSIONS = Set.new(%w[admin maintain write]).freeze
  RISK_MESSAGES = {
    "GitHub API coverage truncated" => "github-api-coverage",
    "untrusted, hidden, or unidentifiable participant(s)" => "untrusted-participants",
    "untrusted comment/review author(s)" => "untrusted-interactions",
    "suspicious text" => "suspicious-text",
    "high-risk files changed" => "high-risk-files"
  }.freeze

  module_function

  def run_gh(*args)
    stdout, stderr, status = Open3.capture3("gh", *args)
    stdout = stdout.force_encoding("UTF-8").scrub
    stderr = stderr.force_encoding("UTF-8").scrub
    return stdout if status.success?

    output = [stderr, stdout].reject(&:empty?).join("\n")
    raise "gh #{args.join(' ')} failed:\n#{output}"
  end

  def run_gh_json(*args)
    JSON.parse(run_gh(*args))
  end

  def current_repo
    run_gh_json("repo", "view", "--json", "nameWithOwner").fetch("nameWithOwner")
  end

  def merged_prs(repo, limit)
    merged = []
    page = 1

    loop do
      prs = closed_pr_page(repo, page)
      break if prs.empty?

      merged.concat(prs.filter_map { |pr| merged_pr_summary(pr) })
      sorted = sort_by_merged_at(merged)
      break if enough_merged_prs?(sorted, prs, limit)

      page += 1
      if page > MAX_CLOSED_PR_PAGES
        warn "WARN: reached #{MAX_CLOSED_PR_PAGES} closed PR pages before proving merged PR sample completeness"
        break
      end
    end

    sort_by_merged_at(merged).first(limit)
  end

  def closed_pr_page(repo, page)
    run_gh_json(
      "api",
      "repos/#{repo}/pulls?state=closed&sort=updated&direction=desc&per_page=100&page=#{page}"
    )
  end

  def merged_pr_summary(pull_request)
    merged_at = pull_request["merged_at"]
    return unless merged_at

    {
      "number" => pull_request.fetch("number"),
      "title" => pull_request.fetch("title"),
      "url" => pull_request.fetch("html_url"),
      "mergedAt" => merged_at
    }
  end

  def sort_by_merged_at(prs)
    prs.sort_by { |pr| Time.iso8601(pr.fetch("mergedAt")) }.reverse
  end

  def enough_merged_prs?(sorted_merged, fetched_page, limit)
    return false if sorted_merged.length < limit

    nth_merged_at = Time.iso8601(sorted_merged.fetch(limit - 1).fetch("mergedAt"))
    oldest_updated_at = fetched_page.filter_map { |pr| pr["updated_at"] }.map { |value| Time.iso8601(value) }.min
    oldest_updated_at && oldest_updated_at < nth_merged_at
  end

  def default_preflight_path
    File.expand_path("../skills/pr-batch/bin/pr-security-preflight", __dir__)
  end

  def run_preflight(preflight_path:, repo:, trust_config:, numbers:)
    args = [preflight_path, "--repo", repo]
    args.concat(["--trust-config", trust_config]) if trust_config
    args.concat(numbers.map(&:to_s))

    output, status = Open3.capture2e(*args)
    [output.force_encoding("UTF-8").scrub, status.exitstatus || 1]
  end

  def normalized_login(login)
    login.to_s.delete_prefix("@").downcase
  end

  def normalized_bot_login(login)
    normalized_login(login).delete_suffix("[bot]")
  end

  def bot_login?(login)
    normalized_login(login).end_with?("[bot]")
  end

  def empty_actor(_login)
    {
      interactions: Set.new,
      permissions: Set.new,
      prs: Set.new,
      urls: Set.new
    }
  end

  def parse_preflight_output(output)
    actors = Hash.new { |hash, key| hash[key] = empty_actor(key) }
    risks = []
    blocked_summary = false
    current_number = nil
    section = nil

    output.each_line do |line|
      case line
      when /^(?:PR|Issue) #(\d+)/
        current_number = Regexp.last_match(1).to_i
        section = nil
      when /^\s+Untrusted or hidden participant findings:/
        section = :participants
      when %r{^\s+Untrusted comment/review queue:}
        section = :interactions
      when /^SECURITY_PREFLIGHT_BLOCKED\b/
        blocked_summary = true
        section = nil
      when /^SECURITY_PREFLIGHT_OK\b/
        blocked_summary = false
        section = nil
      when /^Acknowledged security preflight findings:/
        section = :acknowledged
      when /^\s+\S.*:$/
        section = nil
      end

      parse_participant_line(line, actors, current_number) if section == :participants
      parse_interaction_line(line, actors, current_number) if section == :interactions
      parse_risk_line(line, risks) if blocked_summary
    end

    { actors:, risks: }
  end

  def parse_participant_line(line, actors, current_number)
    match = line.match(/^\s+- ([^:]+): .*; permission=([^\s]+)\s*$/)
    return unless match

    login = match[1].strip
    return if login.start_with?("(")

    actor = actors[login]
    actor[:permissions] << match[2]
    actor[:prs] << current_number if current_number
    actor[:interactions] << "participant"
  end

  def parse_interaction_line(line, actors, current_number)
    match = line.match(/^\s+- (\S+) (issue comment|review comment|pull request review) \(([^)]+)\)\s*$/)
    return unless match

    login = match[1]
    actor = actors[login]
    actor[:interactions] << match[2]
    actor[:urls] << match[3]
    actor[:prs] << current_number if current_number
  end

  def parse_risk_line(line, risks)
    match = line.match(/^- #(\d+): (.+)$/)
    return unless match

    number = match[1].to_i
    message = match[2].strip
    risk_id = RISK_MESSAGES[message]
    warn "WARN: unknown pr-security-preflight risk message: #{message}" unless risk_id
    risk_id ||= "unknown"
    risks << { number:, message:, risk_id: }
  end

  def candidates(parsed)
    trusted_bots = Set.new
    trusted_users = Set.new
    manual_review = []

    parsed.fetch(:actors).each do |login, actor|
      if bot_login?(login) && visible_actor_evidence?(actor)
        trusted_bots << normalized_bot_login(login)
      elsif trusted_user_candidate?(actor) && visible_actor_evidence?(actor)
        trusted_users << login
      else
        manual_review << { login:, actor: }
      end
    end

    { trusted_bots:, trusted_users:, manual_review: }
  end

  def trusted_user_candidate?(actor)
    permissions = actor.fetch(:permissions)
    permissions.any? { |permission| TRUSTED_USER_PERMISSIONS.include?(permission) }
  end

  def visible_actor_evidence?(actor)
    actor.fetch(:urls).any? || actor.fetch(:interactions).any? { |kind| kind != "participant" }
  end

  def preflight_status_label(status)
    case status
    when 0
      "SECURITY_PREFLIGHT_OK"
    when 2
      "SECURITY_PREFLIGHT_BLOCKED"
    else
      "PREFLIGHT_ERROR"
    end
  end

  def preflight_error?(status)
    !status.zero? && status != 2
  end

  def format_set(values)
    values.to_a.sort
  end

  def print_report(repo:, prs:, trust_config:, preflight_status:, preflight_output:, parsed:)
    candidate_data = candidates(parsed)
    puts "Repository: #{repo}"
    puts "Merged PR sample: #{prs.map { |pr| "##{pr.fetch('number')}" }.join(', ')}"
    puts "Trust config: #{trust_config || '(preflight default resolution)'}"
    puts "Preflight status: #{preflight_status_label(preflight_status)}"
    puts

    print_risks(parsed.fetch(:risks), preflight_status:)
    if preflight_error?(preflight_status)
      puts "Candidate repo-local trust entries: unavailable because preflight did not complete."
      puts
      puts "Manual-review actors: unavailable because preflight did not complete."
      puts
    else
      print_candidate_yaml(candidate_data)
      print_manual_review(candidate_data.fetch(:manual_review))
    end

    puts "Raw preflight output:"
    puts preflight_output
  end

  def print_risks(risks, preflight_status:)
    if preflight_error?(preflight_status)
      puts "Blocking risks: unavailable because preflight did not complete"
      puts
      return
    end

    if risks.empty?
      puts "Blocking risks: none"
    else
      puts "Blocking risks:"
      risks.each do |risk|
        puts "  - ##{risk.fetch(:number)}: #{risk.fetch(:risk_id)} (#{risk.fetch(:message)})"
      end
    end
    puts
  end

  def print_candidate_yaml(candidate_data)
    bots = format_set(candidate_data.fetch(:trusted_bots))
    users = format_set(candidate_data.fetch(:trusted_users))

    puts "Candidate repo-local trust entries from this sample:"
    puts "trusted_users:"
    if users.empty?
      puts "  []"
    else
      users.each { |login| puts "  - #{login}" }
    end
    puts
    puts "trusted_bots:"
    if bots.empty?
      puts "  []"
    else
      bots.each { |login| puts "  - #{login}" }
    end
    puts
    puts "trusted_teams:"
    puts "  []"
    puts
    puts "Review before copying these entries. Historical merged PRs are evidence, not authority."
    puts
  end

  def print_manual_review(manual_review)
    if manual_review.empty?
      puts "Manual-review actors: none"
      puts
      return
    end

    puts "Manual-review actors:"
    manual_review.sort_by { |entry| entry.fetch(:login).downcase }.each do |entry|
      actor = entry.fetch(:actor)
      permissions = format_set(actor.fetch(:permissions))
      prs = format_set(actor.fetch(:prs)).map { |number| "##{number}" }
      puts "  - #{entry.fetch(:login)}: permission=#{permissions.empty? ? 'unknown' : permissions.join(',')}; " \
           "prs=#{prs.join(',')}; interactions=#{format_set(actor.fetch(:interactions)).join(',')}"
    end
    puts
  end

  def json_payload(repo:, prs:, trust_config:, preflight_status:, preflight_output:, parsed:)
    candidate_data = candidates(parsed)
    candidate_trust = if preflight_error?(preflight_status)
                        { trusted_users: [], trusted_bots: [], trusted_teams: [], unavailable: true }
                      else
                        {
                          trusted_users: format_set(candidate_data.fetch(:trusted_users)),
                          trusted_bots: format_set(candidate_data.fetch(:trusted_bots)),
                          trusted_teams: []
                        }
                      end
    manual_review_actors = if preflight_error?(preflight_status)
                             []
                           else
                             candidate_data.fetch(:manual_review).map do |entry|
                               actor = entry.fetch(:actor)
                               {
                                 login: entry.fetch(:login),
                                 permissions: format_set(actor.fetch(:permissions)),
                                 prs: format_set(actor.fetch(:prs)),
                                 interactions: format_set(actor.fetch(:interactions)),
                                 urls: format_set(actor.fetch(:urls))
                               }
                             end
                           end

    {
      repo:,
      prs: prs.map { |pr| pr.slice("number", "title", "url", "mergedAt") },
      trust_config:,
      preflight_status: preflight_status_label(preflight_status),
      preflight_exit_status: preflight_status,
      risks: parsed.fetch(:risks),
      candidate_trust:,
      manual_review_actors:,
      preflight_output:
    }
  end

  def run(options)
    repo = options[:repo] || current_repo
    prs = merged_prs(repo, options.fetch(:limit))
    abort "No merged PRs found for #{repo}" if prs.empty?

    numbers = prs.map { |pr| pr.fetch("number") }
    preflight_output, preflight_status = run_preflight(
      preflight_path: options.fetch(:preflight_path),
      repo:,
      trust_config: options[:trust_config],
      numbers:
    )
    parsed = parse_preflight_output(preflight_output)

    if options[:json]
      puts JSON.pretty_generate(
        json_payload(
          repo:,
          prs:,
          trust_config: options[:trust_config],
          preflight_status:,
          preflight_output:,
          parsed:
        )
      )
    else
      print_report(
        repo:,
        prs:,
        trust_config: options[:trust_config],
        preflight_status:,
        preflight_output:,
        parsed:
      )
    end

    preflight_status.zero? ? 0 : preflight_status
  end
end

options = {
  json: false,
  limit: AgentWorkflowsTrustAudit::DEFAULT_LIMIT,
  preflight_path: AgentWorkflowsTrustAudit.default_preflight_path,
  repo: nil,
  trust_config: nil
}

OptionParser.new do |opts|
  opts.banner = "Usage: agent-workflows-trust-audit [--repo OWNER/REPO] [--limit N] " \
                "[--trust-config PATH] [--json]"
  opts.on("--repo OWNER/REPO", "GitHub repository, defaulting to gh repo view") { |value| options[:repo] = value }
  opts.on("--limit N", Integer, "Merged PR sample size, default #{AgentWorkflowsTrustAudit::DEFAULT_LIMIT}") do |value|
    abort "--limit must be positive" unless value.positive?

    options[:limit] = value
  end
  opts.on("--trust-config PATH", "Trust config passed through to pr-security-preflight") do |value|
    options[:trust_config] = value
  end
  opts.on("--preflight PATH", "Path to pr-security-preflight, for tests or custom installs") do |value|
    options[:preflight_path] = value
  end
  opts.on("--json", "Emit JSON") { options[:json] = true }
end.parse!

exit AgentWorkflowsTrustAudit.run(options)
