#!/usr/bin/env bash
set -euo pipefail

agent_stack_bin_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
agent_stack_module_dir="$agent_stack_bin_dir/agent_stack"
agent_stack_bootstrap_source_root="${AGENT_STACK_SOURCE_ROOT:-$HOME/src}"
agent_stack_required_modules=(usage doctor options paths runtime repositories compatibility installers sync)
agent_stack_module_tree_usable() {
  local directory="$1" module
  for module in "${agent_stack_required_modules[@]}"; do [[ -f "$directory/$module.bash" && -r "$directory/$module.bash" ]] || return 1; done
}
agent_stack_arguments=("$@")
for ((agent_stack_index = 0; agent_stack_index < ${#agent_stack_arguments[@]}; agent_stack_index++)); do
  if [[ "${agent_stack_arguments[$agent_stack_index]}" = "--source-root" &&
        -n "${agent_stack_arguments[$((agent_stack_index + 1))]:-}" &&
        "${agent_stack_arguments[$((agent_stack_index + 1))]}" != --* ]]; then
    agent_stack_bootstrap_source_root="${agent_stack_arguments[$((agent_stack_index + 1))]}"
    break
  fi
done
agent_stack_source_module_dir="$agent_stack_bootstrap_source_root/agent-workflows/bin/agent_stack"
if ! agent_stack_module_tree_usable "$agent_stack_module_dir"; then
  [[ "${1:-}" != "doctor" ]] || { echo "agent-stack doctor requires complete modules beside the command" >&2; exit 64; }
  if ! agent_stack_module_tree_usable "$agent_stack_source_module_dir"; then
    echo "agent-stack module trees incomplete beside command and in source checkout: $agent_stack_source_module_dir" >&2
    exit 64
  fi
  agent_stack_module_dir="$agent_stack_source_module_dir"
fi
for module in "${agent_stack_required_modules[@]}"; do source "$agent_stack_module_dir/$module.bash"; done

command="${1:-}"
if [[ "$command" = "-h" || "$command" = "--help" ]]; then
  agent_stack_usage
  exit 0
fi

if [[ "$command" = "doctor" ]]; then
  shift
  agent_stack_run_doctor "$agent_stack_bin_dir" "$agent_stack_bootstrap_source_root" "$@"
fi

if [[ "$command" != "sync" ]]; then
  agent_stack_usage >&2
  exit 64
fi
shift
agent_stack_sync "$@"
