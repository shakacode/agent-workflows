#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "fileutils"
require "find"
require "open3"
require "optparse"

module AgentWorkflowsDeliveryState
  module_function

  def plugin_manifest_valid?(root, host)
    directory = host == "codex" ? ".codex-plugin" : ".claude-plugin"
    path = File.join(root, directory, "plugin.json")
    return false unless File.file?(path)

    manifest = JSON.parse(File.binread(path))
    skills = manifest.fetch("skills")
    return false unless skills.is_a?(String) && !skills.empty?

    skills_root = File.realpath(File.expand_path(skills, root))
    plugin_root = File.realpath(root)
    manifest.fetch("name") == "scw" &&
      (skills_root == plugin_root || skills_root.start_with?("#{plugin_root}/")) &&
      Dir.glob(File.join(skills_root, "*", "SKILL.md")).any?
  rescue Errno::ENOENT, JSON::ParserError, KeyError, TypeError
    false
  end

  def codex_native_state(target)
    config_path = File.join(target, "config.toml")
    config = File.file?(config_path) ? File.binread(config_path) : ""
    malformed_section = config.each_line.any? { |line| line.lstrip.start_with?("[") && !line.strip.end_with?("]") }
    return { "state" => "unknown", "reason" => "invalid Codex plugin state in #{config_path}" } if malformed_section

    section = config[/^\[plugins\.["']scw@agent-workflows["']\]\s*$.*?(?=^\[|\z)/m]
    return { "state" => "inactive", "reason" => "scw@agent-workflows is not enabled" } unless section&.match?(/^enabled\s*=\s*true\s*$/)

    roots = Dir.glob(File.join(target, "plugins/cache/agent-workflows/scw/*")).select do |root|
      plugin_manifest_valid?(root, "codex")
    end
    return { "state" => "unknown", "reason" => "enabled Codex scw plugin has no valid installed cache" } if roots.empty?

    { "state" => "active", "roots" => roots.sort }
  end

  def claude_native_state(target)
    settings_path = File.join(target, "settings.json")
    settings = File.file?(settings_path) ? JSON.parse(File.binread(settings_path)) : {}
    return { "state" => "unknown", "reason" => "invalid Claude plugin settings shape" } unless settings.is_a?(Hash)
    return { "state" => "inactive", "reason" => "scw@agent-workflows is not enabled" } unless settings.dig("enabledPlugins", "scw@agent-workflows") == true

    receipt_path = File.join(target, "plugins/installed_plugins.json")
    return { "state" => "unknown", "reason" => "enabled Claude scw plugin has no install receipt" } unless File.file?(receipt_path)

    receipt_state = JSON.parse(File.binread(receipt_path))
    unless receipt_state.is_a?(Hash) && receipt_state["plugins"].is_a?(Hash)
      return { "state" => "unknown", "reason" => "invalid Claude plugin receipt shape" }
    end

    receipts = receipt_state.dig("plugins", "scw@agent-workflows")
    roots = Array(receipts).filter_map { |receipt| receipt["installPath"] if receipt.is_a?(Hash) }.select do |root|
      plugin_manifest_valid?(root, "claude")
    end
    return { "state" => "unknown", "reason" => "enabled Claude scw plugin has no valid installed cache" } if roots.empty?

    { "state" => "active", "roots" => roots.sort }
  rescue JSON::ParserError, TypeError => e
    { "state" => "unknown", "reason" => "invalid Claude plugin state: #{e.message}" }
  end

  def native_state(host, target)
    host == "codex" ? codex_native_state(target) : claude_native_state(target)
  end

  def read_metadata(target)
    path = File.join(target, ".agent-workflows-install.json")
    return nil unless File.file?(path)

    metadata = JSON.parse(File.binread(path))
    raise JSON::ParserError, "metadata root must be an object" unless metadata.is_a?(Hash)

    %w[source source_revision delivery_mode].each do |key|
      value = metadata[key]
      raise JSON::ParserError, "metadata #{key} must be a string" if !value.nil? && !value.is_a?(String)
    end
    delivery_mode = metadata["delivery_mode"]
    if delivery_mode && !%w[flat plugin-companion].include?(delivery_mode)
      raise JSON::ParserError, "metadata delivery_mode must be flat or plugin-companion"
    end

    metadata
  end

  def git_snapshot_root(source_roots, revision)
    return nil if revision.to_s.empty? || revision == "unknown"

    source_roots.compact.uniq.find do |root|
      File.directory?(root) && system("git", "-C", root, "cat-file", "-e", "#{revision}:skills", out: File::NULL, err: File::NULL)
    end
  end

  def skill_names(source, metadata)
    revision = metadata&.fetch("source_revision", nil)
    roots = [metadata&.fetch("source", nil), source]
    if (git_root = git_snapshot_root(roots, revision))
      output, status = Open3.capture2e("git", "-C", git_root, "ls-tree", "--name-only", "#{revision}:skills")
      return [output.lines.map(&:strip).reject(&:empty?).sort, { type: :git, root: git_root, revision: revision }] if status.success?
    end

    source_root = roots.compact.find { |root| File.directory?(File.join(root, "skills")) }
    names = source_root ? Dir.children(File.join(source_root, "skills")).select { |name| File.directory?(File.join(source_root, "skills", name)) }.sort : []
    [names, source_root ? { type: :directory, root: source_root } : nil]
  end

  def filesystem_entries(root)
    return nil unless File.directory?(root) && !File.symlink?(root)

    entries = {}
    Find.find(root) do |path|
      next if path == root || File.directory?(path) && !File.symlink?(path)

      entries[path.delete_prefix("#{root}/")] = path
    end
    entries
  end

  def matches_directory_snapshot?(installed, snapshot, skill_name)
    actual = filesystem_entries(installed)
    return false unless actual

    expected_root = File.join(snapshot.fetch(:root), "skills", skill_name)
    if snapshot.fetch(:type) == :directory
      expected = filesystem_entries(expected_root)
      return false unless expected && actual.keys.sort == expected.keys.sort

      return actual.all? do |relative, path|
        other = expected.fetch(relative)
        if File.symlink?(path) || File.symlink?(other)
          File.symlink?(path) && File.symlink?(other) && File.readlink(path) == File.readlink(other)
        else
          File.file?(path) && File.file?(other) && File.binread(path) == File.binread(other) &&
          (File.stat(path).mode & 0o111).positive? == (File.stat(other).mode & 0o111).positive?
        end
      end
    end

    revision = snapshot.fetch(:revision)
    output, status = Open3.capture2e("git", "-C", snapshot.fetch(:root), "ls-tree", "-r", revision, "--", "skills/#{skill_name}")
    return false unless status.success?

    expected = output.lines.to_h do |line|
      metadata, path = line.chomp.split("\t", 2)
      mode, type, = metadata.split
      [path.delete_prefix("skills/#{skill_name}/"), [mode, type, path]]
    end
    return false unless actual.keys.sort == expected.keys.sort

    actual.all? do |relative, path|
      mode, type, git_path = expected.fetch(relative)
      blob, blob_status = Open3.capture2("git", "-C", snapshot.fetch(:root), "show", "#{revision}:#{git_path}")
      next false unless blob_status.success?

      if mode == "120000"
        File.symlink?(path) && File.readlink(path) == blob
      else
        type == "blob" && File.file?(path) && !File.symlink?(path) && File.binread(path) == blob.b &&
          (File.stat(path).mode & 0o111).positive? == (mode == "100755")
      end
    end
  end

  def managed_flat_inventory(target:, source:, delivery_mode:)
    metadata = read_metadata(target)
    prior_delivery_mode = metadata&.fetch("delivery_mode", "flat")
    revision = metadata&.fetch("source_revision", nil).to_s
    skills_path = File.join(target, "skills")
    flat_tree_present = if File.symlink?(skills_path) || File.exist?(skills_path) && !File.directory?(skills_path)
                          true
                        else
                          File.directory?(skills_path) && !Dir.empty?(skills_path)
                        end
    if delivery_mode == "plugin-companion" && metadata && prior_delivery_mode == "flat" && flat_tree_present &&
       (revision.empty? || revision == "unknown" || !git_snapshot_root([metadata["source"], source], revision))
      return {
        "state" => "unknown",
        "removable" => [],
        "blocking" => [skills_path],
        "reason" => "recorded source revision is unavailable: #{revision}"
      }
    end

    names, snapshot = skill_names(source, metadata)
    if delivery_mode == "flat"
      present = names.filter_map do |name|
        path = File.join(target, "skills", name)
        path if File.exist?(path) || File.symlink?(path)
      end
      if present.any? && (!metadata || prior_delivery_mode != "flat")
        return { "state" => "ambiguous", "paths" => present.sort, "removable" => [], "blocking" => present.sort }
      end

      return { "state" => present.empty? ? "absent" : "present", "paths" => present.sort, "removable" => [], "blocking" => [] }
    end

    removable = []
    blocking = []
    names.each do |name|
      path = File.join(target, "skills", name)
      next unless File.exist?(path) || File.symlink?(path)

      unless delivery_mode == "plugin-companion" && metadata && prior_delivery_mode == "flat" && snapshot
        blocking << path
        next
      end

      if File.symlink?(path)
        resolved = File.expand_path(File.readlink(path), File.dirname(path))
        allowed = [metadata["source"], source].compact.map { |root| File.expand_path(File.join(root, "skills", name)) }
        (allowed.include?(resolved) ? removable : blocking) << path
      elsif matches_directory_snapshot?(path, snapshot, name)
        removable << path
      else
        blocking << path
      end
    end

    { "state" => if blocking.empty?
                   removable.empty? ? "absent" : "managed"
                 else
                   "ambiguous"
                 end, "removable" => removable.sort, "blocking" => blocking.sort }
  rescue JSON::ParserError => e
    {
      "state" => "unknown",
      "removable" => [],
      "blocking" => [File.join(target, ".agent-workflows-install.json")],
      "reason" => "invalid install metadata: #{e.message}"
    }
  end

  def check(host:, target:, source:, delivery_mode:)
    native = native_state(host, target)
    flat = managed_flat_inventory(target: target, source: source, delivery_mode: delivery_mode)
    native_compatible = native["state"] == (delivery_mode == "plugin-companion" ? "active" : "inactive")
    compatible = native_compatible && flat["state"] != "unknown" && flat["blocking"].empty?
    reason =
      if compatible
        nil
      elsif flat["state"] == "unknown"
        flat["reason"]
      elsif flat["blocking"].any?
        "refusing to remove modified, ambiguous, or unowned skill paths: #{flat['blocking'].join(', ')}"
      elsif native["state"] == "unknown"
        native["reason"]
      elsif delivery_mode == "flat"
        "native scw and installer-managed flat skills cannot be active in one host/profile"
      else
        "plugin-companion mode requires an enabled native scw plugin"
      end
    guidance =
      if flat["blocking"].any?
        "The listed paths were preserved. Restore them to their recorded pack revision or move/remove them manually, then rerun."
      elsif delivery_mode == "flat"
        "Disable or remove scw@agent-workflows, or rerun with --delivery-mode plugin-companion."
      else
        "Install and enable scw@agent-workflows, then rerun with --delivery-mode plugin-companion."
      end
    {
      "compatible" => compatible,
      "delivery_mode" => delivery_mode,
      "native" => native,
      "flat" => flat,
      "reason" => reason,
      "guidance" => compatible ? nil : guidance
    }
  end

  def migrate(**options)
    payload = check(**options)
    return payload unless payload.fetch("compatible")

    removed = payload.dig("flat", "removable")
    removed.each { |path| FileUtils.rm_rf(path) }
    payload["flat"]["removed"] = removed
    payload
  end
end

if $PROGRAM_NAME == __FILE__
  action = ARGV.shift
  options = { json: false }
  parser = OptionParser.new do |opts|
    opts.on("--host HOST") { |value| options[:host] = value }
    opts.on("--target DIR") { |value| options[:target] = File.expand_path(value) }
    opts.on("--source DIR") { |value| options[:source] = File.expand_path(value) }
    opts.on("--delivery-mode MODE") { |value| options[:delivery_mode] = value }
    opts.on("--json") { options[:json] = true }
  end
  parser.parse!

  abort "action must be check or migrate" unless %w[check migrate].include?(action)
  abort "--host, --target, --source, and --delivery-mode are required" unless %i[host target source delivery_mode].all? { |key| options[key] }
  abort "--host must be codex or claude" unless %w[codex claude].include?(options[:host])
  abort "--delivery-mode must be flat or plugin-companion" unless %w[flat plugin-companion].include?(options[:delivery_mode])

  payload = AgentWorkflowsDeliveryState.public_send(action, **options.slice(:host, :target, :source, :delivery_mode))
  puts(options[:json] ? JSON.pretty_generate(payload) : payload.fetch("reason", "delivery state compatible"))
  exit(payload.fetch("compatible") ? 0 : 3)
end
