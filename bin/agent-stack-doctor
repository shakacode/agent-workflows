#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "optparse"
require "time"
require "uri"

MAX_STDOUT = 1024 * 1024
MAX_STDERR = 64 * 1024
DEFAULT_TIMEOUT = 10.0
COMPONENTS = %w[agent-workflows agent-coordination agent-coordination-dashboard].freeze
CHECK_STATUSES = %w[healthy degraded failed skipped].freeze
COMPONENT_STATUSES = %w[healthy degraded failed].freeze
SEVERITY = { "healthy" => 0, "skipped" => 0, "degraded" => 1, "failed" => 2 }.freeze
EXIT_FOR_STATUS = { "healthy" => 0, "degraded" => 1, "failed" => 2 }.freeze

class UsageError < StandardError; end

def usage
  <<~TEXT
    Usage: agent-stack doctor [options]

      --source-root DIR              source checkout root (default: ~/src)
      --compat-root DIR              compatibility symlink root (default: ~/codex/agent-repos)
      --runtime-root DIR             private runtime/config root (default: ~/.agent-workflows)
      --host codex|claude|auto       workflow install host (default: codex)
      --target DIR                   workflow install target
      --agent-coord-install-dir DIR  agent-coord install dir (default: ~/.local/bin)
      --dashboard-url URL            loopback dashboard URL (default: http://127.0.0.1:${PORT:-4319})
      --deep                         run component deep checks
      --json                         emit JSON only
  TEXT
end

def monotonic
  Process.clock_gettime(Process::CLOCK_MONOTONIC)
end

def terminate_group(pid)
  begin
    Process.kill("TERM", -pid)
  rescue Errno::ESRCH
    nil
  end
  deadline = monotonic + 0.5
  loop do
    break if Process.waitpid2(pid, Process::WNOHANG)
    break if monotonic >= deadline

    sleep 0.02
  rescue Errno::ECHILD
    break
  end
  begin
    Process.kill("KILL", -pid)
  rescue Errno::ESRCH
    nil
  end
  begin
    Process.wait(pid)
  rescue Errno::ECHILD
    nil
  end
end

def capture(command, timeout: DEFAULT_TIMEOUT)
  stdout_reader, stdout_writer = IO.pipe
  stderr_reader, stderr_writer = IO.pipe
  pid = Process.spawn(*command, out: stdout_writer, err: stderr_writer, pgroup: true)
  stdout_writer.close
  stderr_writer.close
  stdout = +""
  stderr = +""
  streams = { stdout_reader => [stdout, MAX_STDOUT], stderr_reader => [stderr, MAX_STDERR] }
  deadline = monotonic + timeout
  child_status = nil
  failure = nil

  until child_status && streams.empty?
    remaining = deadline - monotonic
    if remaining <= 0
      failure = "diagnostic timed out"
      terminate_group(pid)
      break
    end
    Array(IO.select(streams.keys, nil, nil, [remaining, 0.05].min)&.first).each do |io|
      buffer, limit = streams.fetch(io)
      chunk = io.read_nonblock(16 * 1024)
      available = limit - buffer.bytesize
      buffer << chunk.byteslice(0, available) if available.positive?
      if chunk.bytesize > available
        failure = "output exceeded diagnostic size limit"
        terminate_group(pid)
        break
      end
    rescue IO::WaitReadable
      next
    rescue EOFError
      streams.delete(io)
      io.close
    end
    break if failure

    child_status ||= Process.waitpid2(pid, Process::WNOHANG)&.last
  end

  { stdout: stdout, stderr: stderr, exit: child_status&.exitstatus, failure: failure }
rescue SystemCallError => e
  { stdout: "", stderr: "", exit: nil, failure: "unable to start diagnostic: #{e.class}" }
ensure
  [stdout_reader, stdout_writer, stderr_reader, stderr_writer].compact.each do |io|
    io.close unless io.closed?
  end
end

def secret_values
  return @secret_values if defined?(@secret_values)

  values = ENV.each_with_object([]) do |(key, value), secrets|
    next unless key.match?(/(?:TOKEN|SECRET|PASSWORD|API_KEY|PRIVATE_KEY)/i)
    next if value.to_s.bytesize < 4

    secrets << value
  end
  @secret_values = values.sort_by { |value| -value.bytesize }
end

def sanitize_url(candidate)
  scrubbed = candidate.gsub(%r{\A(https?://)[^/@\s]+@}i, '\\1[REDACTED]@')
  uri = URI.parse(scrubbed)
  return scrubbed unless uri.is_a?(URI::HTTP) && uri.host

  uri.user = nil
  uri.password = nil
  if uri.query
    pairs = URI.decode_www_form(uri.query).map do |key, value|
      redacted = value.dup
      secret_values.each { |secret| redacted.gsub!(secret, "[REDACTED]") }
      redacted = "[REDACTED]" if key.match?(/(?:token|secret|password|key|credential)/i)
      [key, redacted]
    end
    uri.query = URI.encode_www_form(pairs)
  end
  uri.to_s
rescue URI::InvalidURIError, ArgumentError
  scrubbed.sub(/\?.*(?=#|\z)/, "?[REDACTED]")
end

def sanitize_string(value)
  text = value.to_s.dup
  text.force_encoding(Encoding::UTF_8)
  text = text.scrub("?")
  text = text.gsub(%r{\e\[[0-?]*[ -/]*[@-~]}, "")
  text = text.gsub(/[\u0000-\u0008\u000B\u000C\u000E-\u001F\u007F-\u009F\r\n]/) do |char|
    "\\x#{char.ord.to_s(16).upcase.rjust(2, '0')}"
  end
  text = text.gsub(%r{https?://[^\s]+}i) { |candidate| sanitize_url(candidate) }
  secret_values.each { |secret| text = text.gsub(secret, "[REDACTED]") }
  text
end

def sanitize(value)
  case value
  when Hash
    value.to_h { |key, item| [sanitize_string(key), sanitize(item)] }
  when Array
    value.map { |item| sanitize(item) }
  when String
    sanitize_string(value)
  else
    value
  end
end

def sanitize_check_record(item)
  {
    "id" => sanitize_string(item.fetch("id")),
    "status" => item.fetch("status"),
    "summary" => sanitize_string(item.fetch("summary")),
    "details" => sanitize(item.fetch("details")),
    "guidance" => item["guidance"] && sanitize_string(item["guidance"])
  }
end

def sanitize_component_record(item)
  {
    "schema_version" => 1,
    "component" => item.fetch("component"),
    "status" => item.fetch("status"),
    "checks" => item.fetch("checks").map { |check_item| sanitize_check_record(check_item) }
  }
end

def check(id, status, summary, details: {}, guidance: nil)
  { "id" => id, "status" => status, "summary" => summary, "details" => details, "guidance" => guidance }
end

def component_status(checks)
  status = checks.map { |item| item.fetch("status") }.max_by { |value| SEVERITY.fetch(value) }
  status == "skipped" || status.nil? ? "healthy" : status
end

def component(component_id, checks)
  { "schema_version" => 1, "component" => component_id, "status" => component_status(checks), "checks" => checks }
end

def unavailable_component(component_id, summary, status: "failed", guidance: nil)
  guidance ||= "Install or repair the component doctor, then rerun `agent-stack doctor`."
  component(component_id, [check("#{component_id}.doctor", status, summary, guidance: guidance)])
end

def normalize_contract(payload, expected_component, child_exit)
  raise JSON::ParserError, "unsupported component contract" unless payload.is_a?(Hash)
  raise JSON::ParserError, "unsupported component contract" unless payload["schema_version"] == 1
  raise JSON::ParserError, "component mismatch" unless payload["component"] == expected_component
  raise JSON::ParserError, "invalid component status" unless COMPONENT_STATUSES.include?(payload["status"])
  raise JSON::ParserError, "invalid checks" unless payload["checks"].is_a?(Array) && !payload["checks"].empty?

  seen = {}
  checks = payload["checks"].map do |item|
    valid = item.is_a?(Hash) && item["id"].is_a?(String) && !item["id"].empty? &&
            CHECK_STATUSES.include?(item["status"]) && item["summary"].is_a?(String) &&
            item["details"].is_a?(Hash) && (item["guidance"].nil? || item["guidance"].is_a?(String))
    raise JSON::ParserError, "invalid check contract" unless valid && !seen[item["id"]]

    seen[item["id"]] = true
    check(item["id"], item["status"], item["summary"], details: item["details"], guidance: item["guidance"])
  end
  normalized = component(expected_component, checks)
  raise JSON::ParserError, "component/check status mismatch" unless normalized["status"] == payload["status"]
  raise JSON::ParserError, "component status/exit mismatch" unless EXIT_FOR_STATUS[payload["status"]] == child_exit

  normalized
end

def delegate(component_id, command, unavailable_status: "failed")
  result = capture(command)
  return unavailable_component(component_id, result[:failure], status: unavailable_status) if result[:failure]
  if result[:exit] == 64
    return unavailable_component(component_id, "component doctor was unable to run", status: unavailable_status)
  end

  normalize_contract(JSON.parse(result[:stdout]), component_id, result[:exit])
rescue JSON::ParserError
  unavailable_component(component_id, "component doctor returned malformed JSON or violated contract", status: unavailable_status)
end

def repo_url(name)
  key = "AGENT_STACK_#{name.tr('-', '_').upcase}_URL"
  ENV[key] || "https://github.com/shakacode/#{name}.git"
end

def origin_allowed?(name, origin)
  key = "AGENT_STACK_#{name.tr('-', '_').upcase}_URL"
  return origin == repo_url(name) if ENV.key?(key)

  normalized = origin.sub(/\.git\z/, "")
  ["https://github.com/shakacode/#{name}", "git@github.com:shakacode/#{name}"].include?(normalized)
end

def git_value(path, *arguments)
  result = capture(["git", "-C", path, *arguments], timeout: 3)
  return [nil, result[:failure]] if result[:failure]
  return [nil, "git exited #{result[:exit]}"] unless result[:exit].to_i.zero?

  [result[:stdout].strip, nil]
end

def checkout_check(name, path)
  unless File.directory?(path)
    return check("#{name}.source", "failed", "source checkout missing", details: { "path" => path },
                                                                        guidance: "Run `agent-stack sync` to create the checkout.")
  end
  revision, revision_error = git_value(path, "rev-parse", "--short", "HEAD")
  branch, branch_error = git_value(path, "branch", "--show-current")
  origin, origin_error = git_value(path, "remote", "get-url", "origin")
  dirty, dirty_error = git_value(path, "status", "--porcelain")
  if revision_error || branch_error || origin_error || dirty_error
    return check("#{name}.source", "failed", "source checkout is not a readable Git worktree",
                 details: { "path" => path }, guidance: "Repair or replace the checkout, then rerun doctor.")
  end
  unless origin_allowed?(name, origin)
    return check("#{name}.source", "failed", "origin does not match the configured repository",
                 details: { "path" => path, "origin" => origin },
                 guidance: "Correct the origin or the matching AGENT_STACK_*_URL override.")
  end

  status = branch == "main" && dirty.empty? ? "healthy" : "degraded"
  summary = status == "healthy" ? "source checkout ready" : "source checkout differs from sync-ready main"
  guidance = status == "degraded" ? "Commit or stash local changes and return the checkout to `main` before syncing." : nil
  check("#{name}.source", status, summary,
        details: { "path" => path, "branch" => branch.empty? ? "detached" : branch, "revision" => revision, "dirty" => !dirty.empty? },
        guidance: guidance)
end

def compatibility_check(name, compat_root, source_path)
  path = File.join(compat_root, name)
  unless File.symlink?(path)
    summary = File.exist?(path) ? "compatibility path is not a symlink" : "compatibility link missing"
    return check("#{name}.compatibility", "degraded", summary, details: { "path" => path },
                                                               guidance: "Run `agent-stack sync` to restore compatibility links.")
  end
  raw_target = File.readlink(path)
  expanded_target = File.expand_path(raw_target, File.dirname(path))
  unless File.exist?(path)
    return check("#{name}.compatibility", "degraded", "compatibility link is dangling",
                 details: { "path" => path, "target" => expanded_target },
                 guidance: "Run `agent-stack sync --replace-compat` to replace the dangling link.")
  end
  actual = File.realpath(path)
  expected = File.realpath(source_path)
  if actual == expected
    return check("#{name}.compatibility", "healthy", "compatibility link ready", details: { "path" => path })
  end

  check("#{name}.compatibility", "degraded", "compatibility link targets another checkout",
        details: { "path" => path, "target" => actual },
        guidance: "Run `agent-stack sync --replace-compat` after reviewing the existing path.")
rescue Errno::ENOENT, Errno::EACCES
  check("#{name}.compatibility", "degraded", "compatibility link cannot be resolved",
        details: { "path" => path }, guidance: "Repair or replace the compatibility link, then rerun doctor.")
end

def validate_dashboard_url(value)
  uri = URI.parse(value)
  allowed_hosts = ["localhost", "127.0.0.1", "::1"]
  valid = uri.scheme == "http" && allowed_hosts.include?(uri.hostname) && uri.userinfo.nil? && uri.fragment.nil?
  raise UsageError, "--dashboard-url must use loopback HTTP without credentials" unless valid

  uri.path = "" if uri.path == "/"
  raise UsageError, "--dashboard-url must not include a query or endpoint path" unless uri.query.nil? && uri.path.to_s.empty?

  uri
rescue URI::InvalidURIError
  raise UsageError, "--dashboard-url must be a valid loopback HTTP URL"
end

def resolve_host_and_target(host, target)
  codex_home = File.expand_path(ENV.fetch("CODEX_HOME", File.join(Dir.home, ".codex")))
  claude_home = File.expand_path(ENV.fetch("CLAUDE_HOME", File.join(Dir.home, ".claude")))
  if target
    expanded = File.expand_path(target)
    return [host, expanded] unless host == "auto"

    codex_marker = expanded == codex_home || File.file?(File.join(expanded, "config.toml"))
    claude_marker = expanded == claude_home || File.file?(File.join(expanded, "settings.json")) ||
                    File.file?(File.join(expanded, "plugins", "installed_plugins.json"))
    raise UsageError, "explicit target has both Codex and Claude markers; pass --host" if codex_marker && claude_marker

    return [claude_marker ? "claude" : "codex", expanded]
  end
  return [host, host == "claude" ? claude_home : codex_home] unless host == "auto"

  candidates = []
  candidates << ["codex", codex_home] if ENV.key?("CODEX_HOME") || File.directory?(codex_home)
  candidates << ["claude", claude_home] if ENV.key?("CLAUDE_HOME") || File.directory?(claude_home)
  return ["codex", codex_home] if candidates.empty?
  return candidates.first if candidates.one?

  raise UsageError, "auto host detection found both Codex and Claude homes; pass --host"
end

def command_available?(name)
  return File.executable?(name) if name.include?(File::SEPARATOR)

  ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).any? { |dir| File.executable?(File.join(dir, name)) }
end

def coordination_selector(runtime_root)
  unless ENV["AGENT_COORD_STATE_ROOT"].to_s.strip.empty?
    return ["--state-root", File.expand_path(ENV["AGENT_COORD_STATE_ROOT"].strip)]
  end
  return ["--api-url", ENV["AGENT_COORD_API_URL"].strip] unless ENV["AGENT_COORD_API_URL"].to_s.strip.empty?
  return ["--backend", ENV["AGENT_COORD_BACKEND"].strip] unless ENV["AGENT_COORD_BACKEND"].to_s.strip.empty?
  unless ENV["AGENT_COORD_STATUS_STATE_ROOT"].to_s.strip.empty?
    return ["--state-root", File.expand_path(ENV["AGENT_COORD_STATUS_STATE_ROOT"].strip)]
  end

  runtime_state = File.join(runtime_root, "state")
  return ["--state-root", runtime_state] if File.directory?(runtime_state)

  xdg_root = ENV["XDG_STATE_HOME"].to_s.empty? ? File.join(Dir.home, ".local", "state") : ENV["XDG_STATE_HOME"]
  implicit_state = File.join(xdg_root, "agent-coordination")
  File.directory?(implicit_state) ? ["--state-root", implicit_state] : nil
end

def append_generic(contract, generic_checks)
  component(contract.fetch("component"), generic_checks + contract.fetch("checks"))
end

def human_detail(value)
  value.is_a?(String) ? value : JSON.generate(value)
end

def render_human(payload)
  counts = payload["components"].group_by { |item| item["status"] }.transform_values(&:length)
  puts "Agent Stack Doctor: #{payload['status'].upcase}"
  puts "3 components: #{counts.fetch('healthy', 0)} healthy, #{counts.fetch('degraded', 0)} degraded, #{counts.fetch('failed', 0)} failed"
  payload["components"].sort_by { |item| -SEVERITY.fetch(item["status"]) }.each do |item|
    puts
    puts "[#{item['status'].upcase}] #{item['component']}"
    item["checks"].sort_by { |entry| -SEVERITY.fetch(entry["status"]) }.each do |entry|
      label = entry["id"].split(".").last.tr("_", " ").split.map(&:capitalize).join(" ")
      puts "  [#{entry['status'].upcase}] #{label}: #{entry['summary']}"
      entry["details"].each do |key, value|
        detail_label = key.tr("_", " ").split.map(&:capitalize).join(" ")
        puts "    #{detail_label.ljust(12)} #{human_detail(value)}"
      end
      puts "    #{'Next'.ljust(12)} #{entry['guidance']}" if entry["guidance"]
    end
  end
end

options = {
  source_root: ENV.fetch("AGENT_STACK_SOURCE_ROOT", File.join(Dir.home, "src")),
  compat_root: ENV.fetch("AGENT_STACK_COMPAT_ROOT", File.join(Dir.home, "codex", "agent-repos")),
  runtime_root: ENV.fetch("AGENT_STACK_RUNTIME_ROOT", File.join(Dir.home, ".agent-workflows")),
  host: "codex",
  target: nil,
  install_dir: File.join(Dir.home, ".local", "bin"),
  dashboard_url: "http://127.0.0.1:#{ENV.fetch('PORT', '4319')}",
  deep: false,
  json: false
}

parser = OptionParser.new do |opts|
  opts.on("--source-root DIR") { |value| options[:source_root] = value }
  opts.on("--compat-root DIR") { |value| options[:compat_root] = value }
  opts.on("--runtime-root DIR") { |value| options[:runtime_root] = value }
  opts.on("--host HOST") { |value| options[:host] = value }
  opts.on("--target DIR") { |value| options[:target] = value }
  opts.on("--agent-coord-install-dir DIR") { |value| options[:install_dir] = value }
  opts.on("--dashboard-url URL") { |value| options[:dashboard_url] = value }
  opts.on("--deep") { options[:deep] = true }
  opts.on("--json") { options[:json] = true }
  opts.on("-h", "--help") do
    puts usage
    exit 0
  end
end

begin
  parser.parse!(ARGV)
  raise UsageError, "unexpected arguments" unless ARGV.empty?
  raise UsageError, "--host must be codex, claude, or auto" unless %w[codex claude auto].include?(options[:host])

  dashboard_uri = validate_dashboard_url(options[:dashboard_url])
  host, target = resolve_host_and_target(options[:host], options[:target])
rescue OptionParser::ParseError, UsageError => e
  warn "agent-stack doctor: #{sanitize_string(e.message)}"
  warn usage
  exit 64
end

source_root = File.expand_path(options[:source_root])
compat_root = File.expand_path(options[:compat_root])
runtime_root = File.expand_path(options[:runtime_root])
install_dir = File.expand_path(options[:install_dir])
sources = COMPONENTS.to_h { |name| [name, File.join(source_root, name)] }

workflow_command = [File.join(target, "bin", "agent-workflows-doctor"), "--stack-json", "--host", host,
                    "--target", target, "--source", sources.fetch("agent-workflows")]
workflow_command << "--deep" if options[:deep]
workflow_contract = if File.executable?(workflow_command.first)
                      delegate("agent-workflows", workflow_command)
                    else
                      unavailable_component("agent-workflows", "component doctor executable is missing")
                    end

coord_command = [File.join(install_dir, "agent-coord"), "doctor", "--stack-json"]
coord_command << "--deep" if options[:deep]
selector = coordination_selector(runtime_root)
coord_contract = if !File.executable?(coord_command.first)
                   unavailable_component("agent-coordination", "component doctor executable is missing")
                 elsif selector.nil?
                   unavailable_component("agent-coordination", "no explicit or existing coordination backend found")
                 else
                   delegate("agent-coordination", coord_command + selector)
                 end

node = ENV.fetch("NODE_BIN", "node")
dashboard_script = File.join(sources.fetch("agent-coordination-dashboard"), "bin", "agent-coordination-dashboard.js")
dashboard_command = [node, dashboard_script, "doctor", "--stack-json"]
dashboard_command << "--deep" if options[:deep]
dashboard_command += ["--url", dashboard_uri.to_s]
dashboard_contract = if !File.file?(dashboard_script)
                       unavailable_component("agent-coordination-dashboard", "component doctor executable is missing", status: "degraded")
                     elsif !command_available?(node)
                       unavailable_component("agent-coordination-dashboard", "Node.js is unavailable for the dashboard doctor", status: "degraded")
                     else
                       delegate("agent-coordination-dashboard", dashboard_command, unavailable_status: "degraded")
                     end

contracts = [workflow_contract, coord_contract, dashboard_contract]
components = contracts.map do |contract|
  name = contract.fetch("component")
  generic = [checkout_check(name, sources.fetch(name)), compatibility_check(name, compat_root, sources.fetch(name))]
  append_generic(contract, generic)
end
overall = components.map { |item| item.fetch("status") }.max_by { |status| SEVERITY.fetch(status) }
payload = {
  "schema_version" => 1,
  "status" => overall,
  "deep" => options[:deep],
  "checked_at" => Time.now.utc.iso8601,
  "components" => components.map { |item| sanitize_component_record(item) }
}

if options[:json]
  puts JSON.generate(payload)
else
  render_human(payload)
end
exit EXIT_FOR_STATUS.fetch(payload["status"])
