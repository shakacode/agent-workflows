#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: install-agent-workflows [--host codex|claude|auto] [--target DIR] [--mode copy|symlink]

Installs this shared workflow pack into an agent home.

Default targets:
  --host codex   ${CODEX_HOME:-$HOME/.codex}
  --host claude  ${CLAUDE_HOME:-$HOME/.claude}
  --host auto    an existing Codex or Claude home, if exactly one is detectable

Installed paths:
  <target>/skills/*
  <target>/workflows/*
  <target>/bin/agent-workflow-seam-doctor
  <target>/bin/agent-workflows-status
  <target>/bin/upgrade-agent-workflows
  <target>/.agent-workflows-install.json
USAGE
}

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
host="codex"
target=""
mode="copy"
metadata_name=".agent-workflows-install.json"
bin_helpers=(
  agent-workflow-seam-doctor
  agent-workflows-status
  install-agent-workflows
  upgrade-agent-workflows
)

default_target_for_host() {
  case "$1" in
    codex)
      printf '%s\n' "${CODEX_HOME:-$HOME/.codex}"
      ;;
    claude)
      printf '%s\n' "${CLAUDE_HOME:-$HOME/.claude}"
      ;;
    *)
      return 1
      ;;
  esac
}

resolve_auto_target() {
  local codex_home="${CODEX_HOME:-$HOME/.codex}"
  local claude_home="${CLAUDE_HOME:-$HOME/.claude}"
  local -a candidates=()

  if [[ -n "${CODEX_HOME:-}" || -d "$codex_home" ]]; then
    candidates+=("codex:$codex_home")
  fi
  if [[ -n "${CLAUDE_HOME:-}" || -d "$claude_home" ]]; then
    candidates+=("claude:$claude_home")
  fi

  case "${#candidates[@]}" in
    0)
      printf 'codex:%s\n' "$codex_home"
      ;;
    1)
      printf '%s\n' "${candidates[0]}"
      ;;
    *)
      echo "Auto host detection found both Codex and Claude homes; pass --host codex or --host claude." >&2
      return 64
      ;;
  esac
}

resolve_host_and_target() {
  if [[ -n "$target" ]]; then
    printf '%s:%s\n' "$host" "$target"
    return 0
  fi

  if [[ "$host" = "auto" ]]; then
    resolve_auto_target
  else
    printf '%s:%s\n' "$host" "$(default_target_for_host "$host")"
  fi
}

metadata_value() {
  local key="$1"
  case "$key" in
    version)
      if [[ -f "$repo_root/VERSION" ]]; then
        tr -d '\r\n' < "$repo_root/VERSION"
      else
        printf 'unknown\n'
      fi
      ;;
    source_revision)
      git -C "$repo_root" rev-parse HEAD 2>/dev/null || printf 'unknown\n'
      ;;
    source_branch)
      git -C "$repo_root" branch --show-current 2>/dev/null || true
      ;;
    source_remote)
      git -C "$repo_root" config --get remote.origin.url 2>/dev/null || true
      ;;
    *)
      return 1
      ;;
  esac
}

write_metadata() {
  local metadata_path="$target/$metadata_name"
  local metadata_tmp="$metadata_path.tmp"
  local version source_revision source_branch source_remote installed_at
  version="$(metadata_value version)"
  source_revision="$(metadata_value source_revision)"
  source_branch="$(metadata_value source_branch)"
  source_remote="$(metadata_value source_remote)"
  installed_at="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"

  ruby -rjson -e '
    path, host, mode, source, version, revision, branch, remote, installed_at = ARGV
    metadata = {
      "host" => host,
      "mode" => mode,
      "source" => File.expand_path(source),
      "version" => version,
      "source_revision" => revision,
      "source_branch" => branch,
      "source_remote" => remote,
      "installed_at" => installed_at
    }
    File.write(path, JSON.pretty_generate(metadata) + "\n")
  ' "$metadata_tmp" "$host" "$mode" "$repo_root" "$version" "$source_revision" "$source_branch" "$source_remote" "$installed_at"
  mv "$metadata_tmp" "$metadata_path"
}

copy_children_preserving_unrelated() {
  local source_dir="$1"
  local target_dir="$2"
  local source_path destination
  mkdir -p "$target_dir"

  for source_path in "$source_dir"/*; do
    [[ -e "$source_path" ]] || continue
    destination="$target_dir/$(basename "$source_path")"
    rm -rf "$destination"
    rsync -a "$source_path" "$target_dir/"
  done
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      host="${2:?--host requires codex, claude, or auto}"
      shift 2
      ;;
    --target)
      target="${2:?--target requires a directory}"
      shift 2
      ;;
    --mode)
      mode="${2:?--mode requires copy or symlink}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 64
      ;;
  esac
done

case "$host" in
  codex|claude|auto) ;;
  *)
    echo "--host must be codex, claude, or auto, got: $host" >&2
    exit 64
    ;;
esac

case "$mode" in
  copy|symlink) ;;
  *)
    echo "--mode must be copy or symlink, got: $mode" >&2
    exit 64
    ;;
esac

resolved="$(resolve_host_and_target)"
host="${resolved%%:*}"
target="${resolved#*:}"

if [[ "$mode" = "copy" ]]; then
  mkdir -p "$target/skills" "$target/workflows" "$target/bin"
  copy_children_preserving_unrelated "$repo_root/skills" "$target/skills"
  copy_children_preserving_unrelated "$repo_root/workflows" "$target/workflows"
  for helper in "${bin_helpers[@]}"; do
    install -m 0755 "$repo_root/bin/$helper" "$target/bin/$helper"
  done
else
  mkdir -p "$target/skills" "$target/bin"
  if [[ -e "$target/workflows" && ! -L "$target/workflows" ]]; then
    echo "Refusing to replace non-symlink path: $target/workflows" >&2
    exit 1
  fi
  for skill in "$repo_root"/skills/*; do
    [[ -d "$skill" ]] || continue
    destination="$target/skills/$(basename "$skill")"
    if [[ -e "$destination" && ! -L "$destination" ]]; then
      echo "Refusing to replace non-symlink path: $destination" >&2
      exit 1
    fi
    ln -sfn "$skill" "$destination"
  done
  rm -f "$target/workflows"
  ln -sfn "$repo_root/workflows" "$target/workflows"
  for helper in "${bin_helpers[@]}"; do
    destination="$target/bin/$helper"
    if [[ -e "$destination" && ! -L "$destination" ]]; then
      echo "Refusing to replace non-symlink path: $destination" >&2
      exit 1
    fi
    ln -sfn "$repo_root/bin/$helper" "$destination"
  done
fi

write_metadata

cat <<MSG
Installed ShakaCode agent workflows into:
  $target

Host:
  $host

Add this to PATH if needed:
  export PATH="$target/bin:\$PATH"

Validate a consumer repo with:
  agent-workflow-seam-doctor --shared "$repo_root"

Check for updates with:
  agent-workflows-status --host "$host"
MSG
