#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: install-agent-workflows [--host codex|claude|auto] [--target DIR] [--mode copy|symlink] [--delivery-mode flat|plugin-companion]

Installs this shared workflow pack into an agent home.

Default targets:
  --host codex   ${CODEX_HOME:-$HOME/.codex}
  --host claude  ${CLAUDE_HOME:-$HOME/.claude}
  --host auto    infer from an explicit target's host markers; an unmarked explicit target defaults to Codex

Installed paths:
  <target>/LICENSE
  <target>/skills/* (flat delivery mode only)
  <target>/workflows/*
  <target>/docs/coordination-backend.md
  <target>/docs/review-finding-schema.md
  <target>/docs/agent-workflows-model-routing.md
  <target>/docs/solutions/*
  <target>/bin/agent-workflow-seam-doctor
  <target>/bin/agent-workflows-doctor
  <target>/bin/agent-workflows-status
  <target>/bin/upgrade-agent-workflows
  <target>/.agent-workflows-install.json
USAGE
}

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
host="codex"
target=""
mode="copy"
delivery_mode=""
metadata_name=".agent-workflows-install.json"
delivery_state_script="$repo_root/bin/agent-workflows-delivery-state"
bin_helpers=(
  agent-workflow-seam-doctor
  agent-workflows-delivery-state
  agent-workflows-doctor
  agent-workflows-status
  agent-workflows-trust-audit
  install-agent-workflows
  upgrade-agent-workflows
)

default_target_for_host() {
  case "$1" in
    codex)
      printf '%s\n' "${CODEX_HOME:-$HOME/.codex}"
      ;;
    claude)
      printf '%s\n' "${CLAUDE_HOME:-$HOME/.claude}"
      ;;
    *)
      return 1
      ;;
  esac
}

resolve_auto_target() {
  local codex_home="${CODEX_HOME:-$HOME/.codex}"
  local claude_home="${CLAUDE_HOME:-$HOME/.claude}"
  local -a candidates=()

  if [[ -n "${CODEX_HOME:-}" || -d "$codex_home" ]]; then
    candidates+=("codex:$codex_home")
  fi
  if [[ -n "${CLAUDE_HOME:-}" || -d "$claude_home" ]]; then
    candidates+=("claude:$claude_home")
  fi

  case "${#candidates[@]}" in
    0)
      printf 'codex:%s\n' "$codex_home"
      ;;
    1)
      printf '%s\n' "${candidates[0]}"
      ;;
    *)
      echo "Auto host detection found both Codex and Claude homes; pass --host codex or --host claude." >&2
      return 64
      ;;
  esac
}

resolve_host_and_target() {
  if [[ -n "$target" ]]; then
    target="$(ruby -e 'puts File.expand_path(ARGV.fetch(0))' "$target")"
    if [[ "$host" = "auto" ]]; then
      local codex_home claude_home
      codex_home="$(ruby -e 'puts File.expand_path(ARGV.fetch(0))' "${CODEX_HOME:-$HOME/.codex}")"
      claude_home="$(ruby -e 'puts File.expand_path(ARGV.fetch(0))' "${CLAUDE_HOME:-$HOME/.claude}")"
      local codex_marker=false claude_marker=false
      [[ "$target" = "$codex_home" || -f "$target/config.toml" ]] && codex_marker=true
      [[ "$target" = "$claude_home" || -f "$target/settings.json" || -f "$target/plugins/installed_plugins.json" ]] && claude_marker=true
      if [[ "$codex_marker" = true && "$claude_marker" = true ]]; then
        echo "Explicit target has both Codex and Claude markers; pass --host codex or --host claude." >&2
        return 64
      elif [[ "$claude_marker" = true ]]; then
        printf 'claude:%s\n' "$target"
      elif [[ "$codex_marker" = true ]]; then
        printf 'codex:%s\n' "$target"
      else
        printf 'codex:%s\n' "$target"
      fi
    else
      printf '%s:%s\n' "$host" "$target"
    fi
    return 0
  fi

  if [[ "$host" = "auto" ]]; then
    resolve_auto_target
  else
    printf '%s:%s\n' "$host" "$(default_target_for_host "$host")"
  fi
}

metadata_value() {
  local key="$1"
  case "$key" in
    version)
      if [[ -f "$repo_root/VERSION" ]]; then
        tr -d '\r\n' < "$repo_root/VERSION"
      else
        printf 'unknown\n'
      fi
      ;;
    source_revision)
      git -C "$repo_root" rev-parse HEAD 2>/dev/null || printf 'unknown\n'
      ;;
    source_branch)
      git -C "$repo_root" branch --show-current 2>/dev/null || true
      ;;
    source_remote)
      git -C "$repo_root" config --get remote.origin.url 2>/dev/null || true
      ;;
    *)
      return 1
      ;;
  esac
}

installed_metadata_value() {
  local key="$1"
  local metadata_path="$target/$metadata_name"
  [[ -f "$metadata_path" ]] || return 1

  ruby -rjson -e '
    metadata = JSON.parse(File.read(ARGV.fetch(0)))
    value = metadata[ARGV.fetch(1)]
    exit 1 if value.nil? || value.to_s.empty?
    puts value
  ' "$metadata_path" "$key"
}

validate_delivery_mode() {
  local label="$1"
  case "$delivery_mode" in
    ""|flat|plugin-companion) ;;
    *)
      echo "$label must be flat or plugin-companion, got: $delivery_mode" >&2
      exit 64
      ;;
  esac
}

prepare_metadata() {
  local metadata_path="$target/$metadata_name"
  local metadata_tmp="$metadata_path.tmp"
  local version source_revision source_branch source_remote installed_at
  version="$(metadata_value version)"
  source_revision="$(metadata_value source_revision)"
  source_branch="$(metadata_value source_branch)"
  source_remote="$(metadata_value source_remote)"
  installed_at="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"

  ruby -rjson -e '
    path, host, mode, delivery_mode, source, version, revision, branch, remote, installed_at = ARGV
    metadata = {
      "host" => host,
      "mode" => mode,
      "delivery_mode" => delivery_mode,
      "source" => File.expand_path(source),
      "version" => version,
      "source_revision" => revision,
      "source_branch" => branch,
      "source_remote" => remote,
      "installed_at" => installed_at
    }
    File.write(path, JSON.pretty_generate(metadata) + "\n")
  ' "$metadata_tmp" "$host" "$mode" "$delivery_mode" "$repo_root" "$version" "$source_revision" "$source_branch" "$source_remote" "$installed_at"
}

commit_metadata() {
  local metadata_path="$target/$metadata_name"
  local metadata_tmp="$metadata_path.tmp"
  mv "$metadata_tmp" "$metadata_path"
}

rollback_migration_staging() {
  local staging="$1"
  local skills_root="$target/skills"
  local staged_path
  [[ -n "$staging" && -d "$staging" ]] || return 0
  if [[ -L "$skills_root" || -e "$skills_root" && ! -d "$skills_root" ]]; then
    echo "ROLLBACK_FAILED: unsafe skills root: $skills_root" >&2
    return 1
  fi
  mkdir -p "$skills_root"
  if [[ -L "$skills_root" || ! -d "$skills_root" ]] || ! ruby -e '
    target = File.realpath(ARGV.fetch(0))
    skills = File.realpath(ARGV.fetch(1))
    exit 1 unless File.dirname(skills) == target
  ' "$target" "$skills_root"; then
    echo "ROLLBACK_FAILED: unsafe skills root: $skills_root" >&2
    return 1
  fi
  for staged_path in "$staging"/*; do
    [[ -e "$staged_path" || -L "$staged_path" ]] || continue
    if [[ -L "$skills_root" || ! -d "$skills_root" ]]; then
      echo "ROLLBACK_FAILED: skills root changed during rollback: $skills_root" >&2
      return 1
    fi
    if [[ -e "$target/skills/$(basename "$staged_path")" || -L "$target/skills/$(basename "$staged_path")" ]]; then
      echo "ROLLBACK_FAILED: destination appeared during migration: $target/skills/$(basename "$staged_path")" >&2
      return 1
    fi
    mv "$staged_path" "$target/skills/"
  done
  rmdir "$staging"
}

valid_migration_staging_path() {
  ruby -e '
    target = File.expand_path(ARGV.fetch(0))
    staging = File.expand_path(ARGV.fetch(1))
    exit 1 unless File.dirname(staging) == target
    exit 1 unless File.basename(staging).match?(/\A\.agent-workflows-flat-migration-.+\z/)

    current = File::SEPARATOR
    target.split(File::SEPARATOR).reject(&:empty?).each_with_index do |component, index|
      current = File.join(current, component)
      next unless File.symlink?(current)

      platform_alias = index.zero? && {
        "/tmp" => "/private/tmp",
        "/var" => "/private/var"
      }[current] == File.expand_path(File.readlink(current), File.dirname(current))
      exit 1 unless platform_alias
    end

    stat = File.lstat(staging)
    exit 1 unless stat.directory? && !stat.symlink?
    exit 1 unless File.realpath(File.dirname(staging)) == File.realpath(target)
  ' "$1" "$2"
}

ensure_real_directory() {
  local directory="$1"

  if [[ -L "$directory" ]]; then
    rm -f "$directory"
  fi
  if [[ -e "$directory" && ! -d "$directory" ]]; then
    echo "Refusing to replace non-directory path: $directory" >&2
    exit 1
  fi
  mkdir -p "$directory"
}

copy_children_preserving_unrelated() {
  local source_dir="$1"
  local target_dir="$2"
  local source_path destination
  ensure_real_directory "$target_dir"

  for source_path in "$source_dir"/*; do
    [[ -e "$source_path" ]] || continue
    destination="$target_dir/$(basename "$source_path")"
    rm -rf "$destination"
    rsync -a "$source_path" "$target_dir/"
  done
}

remove_legacy_managed_model_routing_path() {
  local docs_target="$1"
  local legacy_path="$docs_target/model-routing.md"
  local link_target previous_revision previous_source source_root

  previous_source="$(installed_metadata_value source 2>/dev/null || true)"
  if [[ -L "$legacy_path" ]]; then
    link_target="$(readlink "$legacy_path")"
    if [[ "$link_target" == "$repo_root/docs/model-routing.md" || \
          ( -n "$previous_source" && "$link_target" == "$previous_source/docs/model-routing.md" ) ]]; then
      rm -f "$legacy_path"
    fi
    return 0
  fi

  [[ -f "$legacy_path" ]] || return 0
  previous_revision="$(installed_metadata_value source_revision 2>/dev/null || true)"
  [[ -n "$previous_revision" ]] || return 0

  for source_root in "$repo_root" "$previous_source"; do
    [[ -n "$source_root" ]] || continue
    git -C "$source_root" rev-parse --is-inside-work-tree >/dev/null 2>&1 || continue
    git -C "$source_root" cat-file -e "$previous_revision:docs/model-routing.md" 2>/dev/null || continue
    if cmp -s "$legacy_path" <(git -C "$source_root" show "$previous_revision:docs/model-routing.md"); then
      rm -f "$legacy_path"
      return 0
    fi
  done

  if [[ -n "$previous_source" && -f "$previous_source/docs/model-routing.md" ]] &&
     cmp -s "$legacy_path" "$previous_source/docs/model-routing.md"; then
    rm -f "$legacy_path"
  fi
}

copy_pack_docs() {
  local docs_target="$1"
  local doc_name destination
  ensure_real_directory "$docs_target"
  ensure_real_directory "$docs_target/solutions"
  remove_legacy_managed_model_routing_path "$docs_target"

  for doc_name in coordination-backend.md review-finding-schema.md agent-workflows-model-routing.md; do
    destination="$docs_target/$doc_name"
    if [[ -L "$destination" ]]; then
      rm -f "$destination"
    fi
    if [[ -e "$destination" && ! -f "$destination" ]]; then
      echo "Refusing to replace non-file path: $destination" >&2
      exit 1
    fi
    install -m 0644 "$repo_root/docs/$doc_name" "$destination"
  done

  copy_children_preserving_unrelated "$repo_root/docs/solutions" "$docs_target/solutions"
}

link_pack_docs() {
  local docs_target="$1"
  local destination doc_name source_path
  ensure_real_directory "$docs_target"
  ensure_real_directory "$docs_target/solutions"
  remove_legacy_managed_model_routing_path "$docs_target"

  for doc_name in coordination-backend.md review-finding-schema.md agent-workflows-model-routing.md; do
    destination="$docs_target/$doc_name"
    if [[ -e "$destination" && ! -L "$destination" ]]; then
      echo "Refusing to replace non-symlink path: $destination" >&2
      exit 1
    fi
    ln -sfn "$repo_root/docs/$doc_name" "$destination"
  done

  for source_path in "$repo_root"/docs/solutions/*; do
    [[ -e "$source_path" ]] || continue
    destination="$docs_target/solutions/$(basename "$source_path")"
    if [[ -e "$destination" && ! -L "$destination" ]]; then
      echo "Refusing to replace non-symlink path: $destination" >&2
      exit 1
    fi
    ln -sfn "$source_path" "$destination"
  done
}

copy_pack_license() {
  local destination="$target/LICENSE"
  mkdir -p "$target"
  if [[ -L "$destination" ]]; then
    rm -f "$destination"
  fi
  if [[ -e "$destination" && ! -f "$destination" ]]; then
    echo "Refusing to replace non-file path: $destination" >&2
    exit 1
  fi
  install -m 0644 "$repo_root/LICENSE" "$destination"
}

link_pack_license() {
  local destination="$target/LICENSE"
  mkdir -p "$target"
  if [[ -e "$destination" && ! -L "$destination" ]]; then
    echo "Refusing to replace non-symlink path: $destination" >&2
    exit 1
  fi
  ln -sfn "$repo_root/LICENSE" "$destination"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      host="${2:?--host requires codex, claude, or auto}"
      shift 2
      ;;
    --target)
      target="${2:?--target requires a directory}"
      shift 2
      ;;
    --mode)
      mode="${2:?--mode requires copy or symlink}"
      shift 2
      ;;
    --delivery-mode)
      delivery_mode="${2:?--delivery-mode requires flat or plugin-companion}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 64
      ;;
  esac
done

case "$host" in
  codex|claude|auto) ;;
  *)
    echo "--host must be codex, claude, or auto, got: $host" >&2
    exit 64
    ;;
esac

case "$mode" in
  copy|symlink) ;;
  *)
    echo "--mode must be copy or symlink, got: $mode" >&2
    exit 64
    ;;
esac

validate_delivery_mode "--delivery-mode"

resolved="$(resolve_host_and_target)"
host="${resolved%%:*}"
target="${resolved#*:}"
if [[ -z "$delivery_mode" ]]; then
  delivery_mode="$(installed_metadata_value delivery_mode 2>/dev/null || printf 'flat\n')"
  validate_delivery_mode "Installed metadata delivery_mode"
fi

pending_migration_receipt="$target/.agent-workflows-migration-staging"
if [[ ! -f "$pending_migration_receipt" ]]; then
  set +e
  delivery_state="$(ruby "$delivery_state_script" check --host "$host" --target "$target" --source "$repo_root" --delivery-mode "$delivery_mode" --json 2>&1)"
  delivery_status=$?
  set -e
  if [[ "$delivery_status" -ne 0 ]]; then
    ruby -rjson -e '
      payload = JSON.parse(STDIN.read)
      warn "DELIVERY_MODE_CONFLICT: #{payload.fetch("reason")}"
      warn payload.fetch("guidance")
    ' <<< "$delivery_state"
    exit 1
  fi
fi

mkdir -p "$target"
install_lock="$target/.agent-workflows-install.lock"
if ! mkdir "$install_lock" 2>/dev/null; then
  echo "DELIVERY_MODE_CONFLICT: another agent-workflows install or migration holds $install_lock" >&2
  exit 1
fi
release_install_lock() {
  local status=$?
  trap - EXIT
  rmdir "$install_lock" 2>/dev/null || true
  exit "$status"
}
trap release_install_lock EXIT
migration_staging=""
migration_receipt="$target/.agent-workflows-migration-staging"
if [[ -f "$migration_receipt" ]]; then
  IFS= read -r recovered_staging < "$migration_receipt" || recovered_staging=""
  recovered_staging="$(ruby -e 'puts File.expand_path(ARGV.fetch(0))' "$recovered_staging")"
  if ! valid_migration_staging_path "$target" "$recovered_staging"; then
    echo "RECOVERY_FAILED: unsafe migration staging receipt; preserved $migration_receipt" >&2
    rmdir "$install_lock" 2>/dev/null || true
    exit 1
  fi
  prior_delivery_mode="$(installed_metadata_value delivery_mode 2>/dev/null || printf 'flat\n')"
  if [[ "$prior_delivery_mode" = "plugin-companion" ]]; then
    if ! rm -rf "$recovered_staging"; then
      echo "CLEANUP_PENDING: committed plugin-companion mode; preserved $migration_receipt for $recovered_staging" >&2
      rmdir "$install_lock" 2>/dev/null || true
      exit 1
    fi
  elif [[ ! -d "$recovered_staging" ]]; then
    echo "RECOVERY_FAILED: flat migration staging is missing; preserved $migration_receipt" >&2
    rmdir "$install_lock" 2>/dev/null || true
    exit 1
  elif ! rollback_migration_staging "$recovered_staging"; then
    echo "RECOVERY_FAILED: preserved $migration_receipt for $recovered_staging" >&2
    rmdir "$install_lock" 2>/dev/null || true
    exit 1
  fi
  rm -f "$migration_receipt"
fi
metadata_committed=false
release_install_transaction() {
  local status=$?
  trap - EXIT
  if [[ -z "$migration_staging" && -f "$migration_receipt" ]]; then
    IFS= read -r migration_staging < "$migration_receipt" || true
  fi
  if [[ "$metadata_committed" != "true" && -n "$migration_staging" ]]; then
    if rollback_migration_staging "$migration_staging"; then
      rm -f "$migration_receipt"
    else
      echo "RECOVERY_FAILED: rollback incomplete; preserved $migration_receipt for $migration_staging" >&2
      status=1
    fi
  fi
  if [[ "$metadata_committed" != "true" && -f "$target/$metadata_name.tmp" ]]; then
    rm -f "$target/$metadata_name.tmp"
  fi
  rmdir "$install_lock" 2>/dev/null || true
  exit "$status"
}
trap release_install_transaction EXIT

# The pre-lock check avoids mutating an obviously unsafe target. This second
# check is authoritative and holds the advisory install lock through commit.
set +e
delivery_state="$(ruby "$delivery_state_script" check --host "$host" --target "$target" --source "$repo_root" --delivery-mode "$delivery_mode" --json 2>&1)"
delivery_status=$?
set -e
if [[ "$delivery_status" -ne 0 ]]; then
  ruby -rjson -e '
    payload = JSON.parse(STDIN.read)
    warn "DELIVERY_MODE_CONFLICT: #{payload.fetch("reason")}"
    warn payload.fetch("guidance")
  ' <<< "$delivery_state"
  exit 1
fi
prepare_metadata

if [[ "$mode" = "copy" ]]; then
  copy_pack_license
  if [[ "$delivery_mode" = "flat" ]]; then
    ensure_real_directory "$target/skills"
    copy_children_preserving_unrelated "$repo_root/skills" "$target/skills"
  fi
  ensure_real_directory "$target/workflows"
  ensure_real_directory "$target/docs"
  ensure_real_directory "$target/bin"
  copy_children_preserving_unrelated "$repo_root/workflows" "$target/workflows"
  copy_pack_docs "$target/docs"
  for helper in "${bin_helpers[@]}"; do
    destination="$target/bin/$helper"
    if [[ -L "$destination" ]]; then
      rm -f "$destination"
    fi
    if [[ -e "$destination" && ! -f "$destination" ]]; then
      echo "Refusing to replace non-file path: $destination" >&2
      exit 1
    fi
    install -m 0755 "$repo_root/bin/$helper" "$destination"
  done
else
  link_pack_license
  mkdir -p "$target/bin"
  if [[ -e "$target/workflows" && ! -L "$target/workflows" ]]; then
    echo "Refusing to replace non-symlink path: $target/workflows" >&2
    exit 1
  fi
  if [[ "$delivery_mode" = "flat" ]]; then
    mkdir -p "$target/skills"
    for skill in "$repo_root"/skills/*; do
      [[ -d "$skill" ]] || continue
      destination="$target/skills/$(basename "$skill")"
      if [[ -e "$destination" && ! -L "$destination" ]]; then
        echo "Refusing to replace non-symlink path: $destination" >&2
        exit 1
      fi
      ln -sfn "$skill" "$destination"
    done
  fi
  rm -f "$target/workflows"
  ln -sfn "$repo_root/workflows" "$target/workflows"
  link_pack_docs "$target/docs"
  for helper in "${bin_helpers[@]}"; do
    destination="$target/bin/$helper"
    if [[ -e "$destination" && ! -L "$destination" ]]; then
      echo "Refusing to replace non-symlink path: $destination" >&2
      exit 1
    fi
    ln -sfn "$repo_root/bin/$helper" "$destination"
  done
fi

if [[ "$delivery_mode" = "plugin-companion" ]]; then
  set +e
  delivery_state="$(ruby "$delivery_state_script" migrate --host "$host" --target "$target" --source "$repo_root" --delivery-mode "$delivery_mode" --retain-staging --staging-receipt "$migration_receipt" --json 2>&1)"
  delivery_status=$?
  set -e
  if [[ "$delivery_status" -ne 0 ]]; then
    ruby -rjson -e '
      payload = JSON.parse(STDIN.read)
      warn "DELIVERY_MODE_CONFLICT: #{payload.fetch("reason")}"
      warn payload.fetch("guidance")
    ' <<< "$delivery_state"
    exit 1
  fi
  migration_staging="$(ruby -rjson -e 'payload = JSON.parse(STDIN.read); puts payload.dig("flat", "staging")' <<< "$delivery_state")"

  set +e
  delivery_state="$(ruby "$delivery_state_script" check --host "$host" --target "$target" --source "$repo_root" --delivery-mode "$delivery_mode" --json 2>&1)"
  delivery_status=$?
  set -e
  if [[ "$delivery_status" -ne 0 ]]; then
    ruby -rjson -e '
      payload = JSON.parse(STDIN.read)
      warn "DELIVERY_MODE_CONFLICT: final delivery verification failed: #{payload.fetch("reason")}"
      warn payload.fetch("guidance")
    ' <<< "$delivery_state"
    exit 1
  fi
fi

commit_metadata
metadata_committed=true
if [[ -n "$migration_staging" ]]; then
  if rm -rf "$migration_staging"; then
    rm -f "$migration_receipt"
  else
    echo "CLEANUP_PENDING: committed plugin-companion mode; preserved $migration_receipt for $migration_staging" >&2
  fi
fi

cat <<MSG
Installed ShakaCode agent workflows into:
  $target

Host:
  $host

Add this to PATH if needed:
  export PATH="$target/bin:\$PATH"

Initialize a consumer repo with:
  agent-workflow-seam-doctor --init --root /path/to/consumer/repo --shared "$repo_root"

Validate a consumer repo with:
  agent-workflow-seam-doctor --shared "$repo_root"

Check for updates with:
  agent-workflows-status --host "$host"
MSG
