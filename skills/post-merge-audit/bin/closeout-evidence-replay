#!/usr/bin/env ruby
# frozen_string_literal: true

# Replay machine-readable closeout evidence markers from PR bodies, issue
# comments, or saved handoff files. The visible Markdown remains the operator
# interface; these hidden markers make post-merge audit recovery deterministic.

require "json"

module CloseoutEvidenceReplay
  module_function

  VALID_QA_STATUSES = %w[satisfied blocked waived in_progress unknown not_applicable].freeze
  VALID_QA_REQUIRED = %w[yes no].freeze
  VALID_RELEASE_BLOCKING = %w[clear blocked waived not_applicable].freeze
  VALID_PROCESS_GAP_DISPOSITIONS = ["script", "schema", "checklist+replay", "park", "not applicable", "not_applicable"].freeze
  VALID_PRIORITY_SEVERITIES = %w[P0 P1 P2 Must-Fix BLOCKING].freeze
  VALID_PRIORITY_DISPOSITIONS = %w[fixed waived false_positive not_applicable deferred_with_issue].freeze

  def run(argv)
    path = argv.fetch(0, nil)
    if path.nil? || path == "-h" || path == "--help"
      puts usage
      return path.nil? ? 64 : 0
    end

    text = path == "-" ? $stdin.read : File.read(path, encoding: "UTF-8")
    puts JSON.pretty_generate(replay(text))
    0
  rescue Errno::ENOENT => e
    warn "Error: #{e.message}"
    1
  end

  def usage
    <<~USAGE
      Usage: closeout-evidence-replay <path|-> [--help]

      Parse `qa-evidence v1` and `priority-finding-dispositions v1` markers from
      a PR body, issue comment, handoff, or stdin and emit replay JSON.
    USAGE
  end

  def replay(text)
    qa = replay_qa_markers(marker_bodies(text, "qa-evidence v1"))
    priority = replay_priority_markers(marker_bodies(text, "priority-finding-dispositions v1"))
    {
      "overall_verdict" => overall_verdict([qa, priority]),
      "qa_evidence" => qa,
      "priority_finding_dispositions" => priority
    }
  end

  def marker_bodies(text, name)
    text.scan(/<!--\s*#{Regexp.escape(name)}\s*(.*?)-->/m).map(&:first)
  end

  def replay_qa_markers(markers)
    return unknown("qa-evidence marker missing") if markers.empty?

    aggregate_marker_results(markers.map { |marker| replay_qa(marker) })
  end

  def replay_priority_markers(markers)
    return priority_not_applicable("priority-finding-dispositions marker missing") if markers.empty?

    aggregate_marker_results(markers.map { |marker| replay_priority(marker) })
  end

  def replay_qa(marker)
    fields = parse_fields(marker)
    missing = missing_fields(
      fields,
      %w[required status tested_at scope automated_checks manual_checks findings release_blocking process_gap_disposition]
    )
    required = fields.fetch("required", "").to_s
    status = fields.fetch("status", "").to_s
    release_blocking = fields.fetch("release_blocking", "").to_s
    process_gap_disposition = fields.fetch("process_gap_disposition", "").to_s
    missing << "required" unless required.empty? || VALID_QA_REQUIRED.include?(required)
    missing << "status" unless status.empty? || VALID_QA_STATUSES.include?(status)
    missing << "release_blocking" unless release_blocking.empty? || VALID_RELEASE_BLOCKING.include?(release_blocking)
    unless process_gap_disposition.empty? || VALID_PROCESS_GAP_DISPOSITIONS.include?(process_gap_disposition)
      missing << "process_gap_disposition"
    end

    verdict =
      if status == "blocked" || release_blocking == "blocked"
        "BLOCKED"
      elsif missing.any?
        "UNKNOWN"
      elsif status == "not_applicable" || required == "no"
        "NOT_APPLICABLE"
      elsif status == "waived" || release_blocking == "waived"
        "WAIVED"
      elsif status == "satisfied" && release_blocking == "clear"
        "SATISFIED"
      else
        "UNKNOWN"
      end

    {
      "verdict" => verdict,
      "fields" => fields,
      "missing" => missing
    }
  end

  def replay_priority(marker)
    fields = parse_fields(marker)
    findings = parse_findings(marker)
    missing = []

    if fields.fetch("status", "") == "not_applicable" && findings.empty?
      return {
        "verdict" => "NOT_APPLICABLE",
        "fields" => fields,
        "findings" => [],
        "missing" => []
      }
    end

    missing << "head_sha" if fields.fetch("head_sha", "").empty?
    missing << "finding" if findings.empty?
    findings.each_with_index do |finding, index|
      %w[url severity disposition evidence].each do |field|
        missing << "finding[#{index}].#{field}" if finding.fetch(field, "").empty?
      end
      disposition = finding.fetch("disposition", "")
      severity = finding.fetch("severity", "")
      unless severity.empty? || VALID_PRIORITY_SEVERITIES.include?(severity)
        missing << "finding[#{index}].severity"
      end
      unless disposition.empty? || VALID_PRIORITY_DISPOSITIONS.include?(disposition)
        missing << "finding[#{index}].disposition"
      end
      if disposition == "waived" && finding.fetch("waiver", "").empty?
        missing << "finding[#{index}].waiver"
      end
    end

    verdict =
      if missing.any?
        "UNKNOWN"
      elsif findings.any? { |finding| finding.fetch("disposition", "") == "waived" }
        "WAIVED"
      else
        "SATISFIED"
      end

    {
      "verdict" => verdict,
      "fields" => fields,
      "findings" => findings,
      "missing" => missing
    }
  end

  def aggregate_marker_results(results)
    return results.first.merge("marker_count" => 1) if results.length == 1

    aggregate = {
      "verdict" => aggregate_verdict(results),
      "fields" => {},
      "missing" => aggregate_missing(results),
      "marker_count" => results.length,
      "markers" => results
    }
    if results.any? { |result| result.key?("findings") }
      aggregate["findings"] = results.flat_map { |result| result.fetch("findings", []) }
    end
    aggregate
  end

  def aggregate_missing(results)
    results.each_with_index.flat_map do |result, index|
      result.fetch("missing", []).map { |missing| "marker[#{index}].#{missing}" }
    end
  end

  def aggregate_verdict(results)
    verdicts = results.map { |result| result.fetch("verdict") }
    return "BLOCKED" if verdicts.include?("BLOCKED")
    return "UNKNOWN" if verdicts.include?("UNKNOWN")
    return "WAIVED" if verdicts.include?("WAIVED")
    return "NOT_APPLICABLE" if verdicts.all? { |verdict| verdict == "NOT_APPLICABLE" }

    "SATISFIED"
  end

  def parse_fields(marker)
    marker.each_line.with_object({}) do |line, fields|
      next if line.strip.start_with?("finding:")

      key, value = line.split(":", 2)
      next if value.nil?

      fields[key.strip.downcase] = value.strip
    end
  end

  def parse_findings(marker)
    marker.each_line.filter_map do |line|
      next unless line.strip.start_with?("finding:")

      raw = line.split(":", 2).last.to_s
      raw.split("|").each_with_object({}) do |part, finding|
        key, value = part.split("=", 2)
        next if value.nil?

        finding[key.strip.downcase] = value.strip
      end
    end
  end

  def missing_fields(fields, required)
    required.select { |field| fields.fetch(field, "").empty? }
  end

  def unknown(reason)
    {
      "verdict" => "UNKNOWN",
      "fields" => {},
      "missing" => [reason]
    }
  end

  def priority_not_applicable(reason)
    {
      "verdict" => "NOT_APPLICABLE",
      "fields" => { "status" => "not_applicable" },
      "findings" => [],
      "missing" => [],
      "reason" => reason
    }
  end

  def overall_verdict(results)
    aggregate_verdict(results)
  end
end

exit(CloseoutEvidenceReplay.run(ARGV)) if $PROGRAM_NAME == __FILE__
